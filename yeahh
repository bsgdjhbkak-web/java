local function drawTracer(origin, direction)
    local myModel = getModel:Invoke(LocalPlayer)
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {myModel, Camera}
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.RespectCanCollide = false
    local result = workspace:Raycast(origin, direction * 2500, params)
    local endPos = result and result.Position or (origin + direction * 2500)
    local lifetime = Options.TracerLifetime and Options.TracerLifetime.Value or 4
    local length = (endPos - origin).Magnitude
    if length < 0.01 then return end
    local seg = Instance.new("Part")
    seg.Anchored=true; seg.CanCollide=false; seg.CanQuery=false; seg.CastShadow=false
    seg.Material=Enum.Material.ForceField; seg.Color=Color3.fromRGB(0,255,255)
    seg.Transparency=0.15; seg.Size=Vector3.new(0.06,0.06,length)
    seg.CFrame=CFrame.new(origin,endPos)*CFrame.new(0,0,-length/2)
    seg.Parent=Camera; Debris:AddItem(seg, lifetime)
    if result then
        local dot = Instance.new("Part")
        dot.Anchored=true; dot.CanCollide=false; dot.CanQuery=false
        dot.Material=Enum.Material.ForceField; dot.Color=Color3.fromRGB(0,255,255)
        dot.Transparency=0.1; dot.Size=Vector3.new(0.2,0.2,0.2)
        dot.Shape=Enum.PartType.Ball; dot.CFrame=CFrame.new(endPos)
        dot.Parent=Camera; Debris:AddItem(dot, lifetime)
    end
end

