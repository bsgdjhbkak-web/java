task.spawn(function()
    local CharacterController=nil
    while true do
        if not CharacterController then
            local mod=findModule("CharacterController")
            if mod then
                local ok,result=pcall(require,mod)
                if ok and result and result.Update then
                    CharacterController=result
                    if not getgenv().cumyin_OldCharUpdate then
                        getgenv().cumyin_OldCharUpdate=CharacterController.Update
                    end
                    CharacterController.Update=function(self,inputVector,deltaTime)
                        if not self or not self._localActor then
                            return getgenv().cumyin_OldCharUpdate(self,inputVector,deltaTime)
                        end
                        if CharSettings.InfStamina then
                            self._exhaustStart=tick(); self._exhausted=tick()+1
                        end
                        local walkMult=CharSettings.WalkSpeedMult or 1
                        local sprintMult=CharSettings.SprintSpeedMult or 1
                        local activeMult=self.IsSprinting and sprintMult or walkMult
                        local baseWeight=self._weightMulti or 1
                        self._weightMulti=baseWeight*activeMult

                        if CharSettings.FlyEnabled then
                            self.VelocityGravity=0; self.HeightState=0; self.IsGrounded=true
                            local camCF=camera.CFrame; local dir=Vector3.new(0,0,0)
                            if inputVector.Magnitude>0 then
                                dir=dir+(camCF.LookVector*-inputVector.Y)+(camCF.RightVector*inputVector.X)
                            end
                            if user_input_service:IsKeyDown(Enum.KeyCode.Space) then dir=dir+Vector3.new(0,1,0) end
                            if user_input_service:IsKeyDown(Enum.KeyCode.LeftControl) then dir=dir-Vector3.new(0,1,0) end
                            if dir.Magnitude>0 then
                                local spd=CharSettings.FlySpeed or 50
                                local sprint=user_input_service:IsKeyDown(Enum.KeyCode.LeftShift) and 2.5 or 1
                                local nextPos=self._position+(dir.Unit*spd*sprint*deltaTime)
                                self._position=nextPos; self._lastSafePosition=nextPos
                                if self._localActor then
                                    self._localActor.SimulatedPosition=nextPos
                                    self._localActor.Grounded=true; self._localActor.Sprinting=false
                                end
                            end
                            local char=self._localActor and (self._localActor.Character or self._localActor._model)
                            if char then
                                local root=char:FindFirstChild("Root") or char.PrimaryPart
                                if root then
                                    root.Velocity=Vector3.new(0,0,0)
                                    root.AssemblyLinearVelocity=Vector3.new(0,0,0)
                                    root.CFrame=CFrame.new(self._position, self._position+camCF.LookVector)
                                end
                            end
                            self._weightMulti=baseWeight; return
                        end
                        local res=getgenv().cumyin_OldCharUpdate(self,inputVector,deltaTime)
                        self._weightMulti=baseWeight
                        return res
                    end

                    if not getgenv().cumyin_OldCharExhaust then
                        getgenv().cumyin_OldCharExhaust=CharacterController._exhaust
                    end
                    CharacterController._exhaust=function(self,...)
                        if CharSettings.InfStamina then return true end
                        return getgenv().cumyin_OldCharExhaust(self,...)
                    end
