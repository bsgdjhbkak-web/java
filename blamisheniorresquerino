-- Refresh dropdown helper
local function RefreshVTPDropdown()
    local vals={}
    if #VTP_Waypoints==0 then
        vals={"(none)"}
    else
        for _,wp in ipairs(VTP_Waypoints) do
            table.insert(vals, wp.name)
        end
    end
    vtpDropdown:SetValues(vals)
end

