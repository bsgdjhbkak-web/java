-- ============================================================
local lastRageShot = 0

local function UpdateRagebot()
    if not Config.RageMode then return end
    
    local equipped = WeaponManager.Equipped or (InventoryService and InventoryService.Equipped and InventoryService.Equipped.Handler)
    if not equipped then return end
    
    -- Get target from ActorManager (already set by GetCombatTarget)
    local targetPart = ActorManager.SelectedTarget_RB
    local targetActor = ActorManager.SelectedActor_RB
    
    if not targetPart or not targetPart.Parent or not targetActor or not targetActor.Alive then
        return
    end
    
    -- Calculate fire delay
    local weaponRPM = 600
    if Config.CustomRPM and Config.RPMValue then
        weaponRPM = Config.RPMValue
    elseif equipped._firearm and equipped._firearm.Tune then
        weaponRPM = equipped._firearm.Tune.RPM or 600
    end
    
    local fireDelay = 60 / weaponRPM
    local now = tick()
    
    if now - lastRageShot >= fireDelay then
        -- Check ammo
        local hasAmmo = true
        if not Config.InfiniteAmmo then
            local mag = equipped._mag
            hasAmmo = (mag and (mag.Ammo or 0) > 0)
        end
        
        if hasAmmo and equipped.Discharge then
            lastRageShot = now
            pcall(function()
                equipped:Discharge(Camera.CFrame)
            end)
        end
    end
end

