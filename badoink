local function applyChamsToChar(character, visColor, hidColor, doVisCheck)
    -- Determine if visible via raycast
    local isVis = true
    if doVisCheck then
        local myRoot = LocalPlayer.Character and LocalPlayer.Character.PrimaryPart
        local theirRoot = character.PrimaryPart or character:FindFirstChild("HumanoidRootPart")
        if myRoot and theirRoot then
            local origin = myRoot.Position
            local dir = (theirRoot.Position - origin)
            local params = RaycastParams.new()
            params.FilterDescendantsInstances = { LocalPlayer.Character, character }
            params.FilterType = Enum.RaycastFilterType.Exclude
            isVis = not workspace:Raycast(origin, dir, params)
        end
    end
    local col = isVis and visColor or hidColor
    return col, isVis
end

local function setChamsParts(character, col)
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            part.Color = col
            part.Material = Enum.Material.Neon
            part.Transparency = 0
        end
    end
end

local function restoreChams(player)
    local data = chamsData[player]
    if not data then return end
    for part, orig in pairs(data.parts) do
        if part and part.Parent then
            part.Color = orig.Color
            part.Material = orig.Material
            part.Transparency = orig.Transparency
        end
    end
    if data.nameLabel then data.nameLabel:Remove() end
    if data.distLabel then data.distLabel:Remove() end
    chamsData[player] = nil
end

local function saveOriginalParts(character, player)
    local parts = {}
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            parts[part] = { Color = part.Color, Material = part.Material, Transparency = part.Transparency }
        end
    end
    local nameLabel = Drawing.new("Text")
    nameLabel.Visible = false; nameLabel.Color = Color3.new(1,1,1)
    nameLabel.Size = 14; nameLabel.Center = true; nameLabel.Outline = true
    nameLabel.Font = Drawing.Fonts.Monospace
    local distLabel = Drawing.new("Text")
    distLabel.Visible = false; distLabel.Color = Color3.new(0.8,0.8,0.8)
    distLabel.Size = 12; distLabel.Center = true; distLabel.Outline = true
