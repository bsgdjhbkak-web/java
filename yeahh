local function updateHitboxes()
    local enabled = Toggles.HitboxEnabled and Toggles.HitboxEnabled.Value
    local size = Options.HitboxSize and Options.HitboxSize.Value or 5
    local transparency = Options.HitboxTransparency and Options.HitboxTransparency.Value or 0
    local color = Options.HitboxColor and Options.HitboxColor.Value or Color3.fromRGB(255,0,0)
    local material = materialMap[Options.HitboxMaterial and Options.HitboxMaterial.Value or 'Default']
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local ok, model = pcall(function() return getModel:Invoke(player) end)
        if not ok or not model then continue end
        local hitboxFolder = model:FindFirstChild("Hitbox")
        if not hitboxFolder then continue end
        for _, part in pairs(hitboxFolder:GetChildren()) do
            if part:IsA("BasePart") then
                if enabled then
                    if not originalHitboxSizes[part] then
                        originalHitboxSizes[part] = part.Size
                        originalHitboxProps[part] = {Transparency=part.Transparency, Color=part.Color, Material=part.Material}
                    end
                    part.Size = Vector3.new(size,size,size)
                    part.Transparency = transparency; part.Color = color
                    if material then part.Material = material end
                else
                    if originalHitboxSizes[part] then
                        part.Size = originalHitboxSizes[part]
                        local props = originalHitboxProps[part]
                        if props then part.Transparency=props.Transparency; part.Color=props.Color; part.Material=props.Material end
                        originalHitboxSizes[part] = nil; originalHitboxProps[part] = nil
                    end
                end
            end
        end
    end
end

