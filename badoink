-- ============================================================
-- MOD DETECTION
-- ============================================================
local MOD_IDS = { [708796191]=true, [1522254052]=true, [48332771]=true, [38491541]=true }

local function checkModPlayer(player)
    if not (Toggles.ModDetEnabled and Toggles.ModDetEnabled.Value) then return end
    if MOD_IDS[player.UserId] then
        pushNotification("md: " .. player.Name)
        game.Players.LocalPlayer:Kick("mod detected")
    end
end

-- check players already in server
for _, p in pairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then
        task.spawn(checkModPlayer, p)
    end
end

-- check players joining
Players.PlayerAdded:Connect(function(p)
    task.spawn(checkModPlayer, p)
end)

