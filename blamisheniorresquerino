-- Waypoint state
local VTP_Waypoints       = {}   -- {name=string, pos=Vector3, rotY=number}
local VTP_LoopEnabled     = false
local VTP_LoopConn        = nil
local VTP_WaypointLabels  = {}   -- LinoriaLib label references for live updates

local function GetNetwork_VTP()
    if Network then return Network end
    -- getnilinstances scan
    pcall(function()
        for _, obj in pairs(getnilinstances()) do
            if obj:IsA("ModuleScript") and obj.Name:lower():find("network") then
                local s,v=pcall(require,obj)
                if s and type(v)=="table" and v.FireServer then Network=v; return end
            end
        end
    end)
    if Network then return Network end
    -- GC scan
    for _,v in pairs(getgc(true)) do
        if type(v)=="table" then
            if rawget(v,"_key") and type(rawget(v,"_key"))=="table" and rawget(v,"_code") then
                Network=v; return Network
            end
            if rawget(v,"FireServer") and rawget(v,"_events") then
                Network=v; return Network
            end
        end
    end
    return nil
end

local function GetActiveVehicleController()
    if ControllerService and ControllerService.Controller and ControllerService.Controller._vehicle then
        return ControllerService.Controller
    end
    local myVehUID=nil
    local localActor=ReplicatorService and ReplicatorService.LocalActor
    if localActor then
        if localActor.Seat then
            myVehUID=localActor.Seat.UID
            if not myVehUID and localActor.Seat._vehicle then myVehUID=localActor.Seat._vehicle.UID end
        elseif localActor.Turret then
            if localActor.Turret._vehicle then myVehUID=localActor.Turret._vehicle.UID
            elseif localActor.Turret._uid then myVehUID=localActor.Turret._uid:split("_")[1] end
        end
    end
    if VehicleService and VehicleService.Vehicles then
        local char=LocalPlayer.Character
        local root=char and (char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart)
        local hum=char and char:FindFirstChild("Humanoid")
        local seat=hum and hum.SeatPart
        for _,veh in pairs(VehicleService.Vehicles) do
            if veh and type(veh)=="table" then
                if myVehUID and tostring(veh.UID)==tostring(myVehUID) then
                    return {_vehicle=veh, _solver=veh._solver or {}}
                end
                if veh.Model then
                    if seat and seat:IsDescendantOf(veh.Model) then
                        return {_vehicle=veh, _solver=veh._solver or {}}
                    end
                    if veh.Owner==LocalPlayer or veh.Owner==LocalPlayer.Name
                    or veh._owner==LocalPlayer or (veh._owner and veh._owner.Name==LocalPlayer.Name) then
                        local tp=veh.Model.PrimaryPart or veh.Model:FindFirstChildOfClass("BasePart")
                        local dist=(tp and root) and (root.Position-tp.Position).Magnitude or 9999
                        if dist<80 or dist==9999 then return {_vehicle=veh, _solver=veh._solver or {}} end
                    end
                end
            end
        end
    end
    return nil
end

local function TeleportVehicle(targetPos, targetRotY)
    local controller=GetActiveVehicleController()
    local newCF=CFrame_new(targetPos)
    if targetRotY then newCF=newCF*CFrame.Angles(0,math.rad(targetRotY),0) end
    local net=Network or GetNetwork_VTP()
    if not net then
        Library:Notify("VTP: Network not found!", 3); return false
    end
    local vehicle=controller and controller._vehicle
    if not vehicle then
        -- character teleport fallback
        local char=LocalPlayer.Character
        local root=char and (char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart)
        if root then
            local offsetCF=newCF*CFrame_new(0,5,0)
            pcall(function()
                if ControllerService and ControllerService.Controller and ControllerService.Controller.SetCFrame then
                    ControllerService.Controller:SetCFrame(offsetCF)
                else root.CFrame=offsetCF end
            end)
            root.Velocity=Vector3.new(0,0,0)
            Library:Notify("VTP: Character teleported", 2)
        end
        return true
    end
    local x,y,z,r00,r01,r02,r10,r11,r12,r20,r21,r22=newCF:GetComponents()
    local steering=(vehicle and vehicle.Steering) or 0
    local throttle=(vehicle and vehicle.Throttle) or 0
    local components=(vehicle and vehicle.ComponentReplicates) or {}
    pcall(function()
        net:FireServer("ReplicateVehicle",vehicle.UID,x,y,z,r00,r01,r02,r10,r11,r12,r20,r21,r22,steering,throttle,components)
    end)
    if vehicle.Hitbox then vehicle.Hitbox.CFrame=newCF end
    vehicle.CFrame=newCF
    if controller._solver and controller._solver.SetState then
        controller._solver:SetState(newCF,Vector3.new(0,0,0),Vector3.new(0,0,0),components)
    end
    Library:Notify("VTP: Teleported!", 2)
    return true
end

local function StartVTPLoop(waypointIndex)
    if VTP_LoopConn then VTP_LoopConn:Disconnect(); VTP_LoopConn=nil end
    VTP_LoopEnabled=true
    VTP_LoopConn=RunService.Heartbeat:Connect(function()
        if not VTP_LoopEnabled then VTP_LoopConn:Disconnect(); VTP_LoopConn=nil; return end
        local wp=VTP_Waypoints[waypointIndex]
        if wp then TeleportVehicle(wp.pos, wp.rotY) end
    end)
    table.insert(getgenv().BlackhawkESP_Connections, VTP_LoopConn)
end

local function StopVTPLoop()
    VTP_LoopEnabled=false
    if VTP_LoopConn then VTP_LoopConn:Disconnect(); VTP_LoopConn=nil end
end

