    _cachedCfg.MaxDistance=Config.MaxDistance or 2000
    _cachedCfg.UseBoxESP=Config.UseBoxESP; _cachedCfg.BoxStyle=Config.BoxStyle; _cachedCfg.BoxScale=Config.BoxScale or 1
