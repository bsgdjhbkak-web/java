-- Save current position as waypoint
VehRight:AddButton({Text="Save Position as Waypoint",Func=function()
    local char=LocalPlayer.Character
    local root=char and (char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart)
    -- prefer vehicle controller position if in vehicle
    local ctrl=GetActiveVehicleController()
    local pos
    if ctrl and ctrl._vehicle then
        pos=(ctrl._vehicle.Hitbox and ctrl._vehicle.Hitbox.CFrame.Position) or ctrl._vehicle.CFrame.Position
    elseif root then
        pos=root.Position
    end
    if not pos then Library:Notify("VTP: No position found", 3); return end
    local idx=#VTP_Waypoints+1
    local name="WP "..idx
    local rotY=0
    if root then
        local _,ry=root.CFrame:ToOrientation(); rotY=math.deg(ry)
    end
    VTP_Waypoints[idx]={name=name, pos=pos, rotY=rotY}
    vtpPosLabel:SetText(string_format("Saved #%d: %.0f,%.0f,%.0f",idx,pos.X,pos.Y,pos.Z))
    Library:Notify("VTP: Saved waypoint "..idx, 2)
end})

