-- We control our clone independently.
-- ============================================================
local hitmarkClone  = nil
local hitmarkAngle  = 0

local function getOrCreateHitmarkClone()
    -- Return existing clone if still valid
    if hitmarkClone and hitmarkClone.Parent then return hitmarkClone end
    hitmarkClone = nil

    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if not pg then return nil end
    local cursor = pg:FindFirstChild("Cursor")
    if not cursor then return nil end
    local dot = cursor:FindFirstChild("dot")
    if not dot then return nil end

    -- Find existing clone first
    local existing = dot:FindFirstChild("cumyin_hitmark")
    if existing then hitmarkClone = existing; return hitmarkClone end

    -- Duplicate from original
    local original = dot:FindFirstChild("hitmark")
    if not original then return nil end

    local clone = original:Clone()
    clone.Name = "cumyin_hitmark"
    clone.Visible = false
    clone.ZIndex = original.ZIndex + 1  -- render on top
    clone.Parent = dot
    hitmarkClone = clone
    return hitmarkClone
end

