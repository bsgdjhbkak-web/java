local function scan_for_best_target()
    if not (Toggles.SilentAimEnabled and Toggles.SilentAimEnabled.Value) then
        CurrentSilentAimTarget=nil; return
    end
    local maxFOVSqr=(Options.FOVRadius and Options.FOVRadius.Value or 400)^2
    local screenCenter=camera.ViewportSize/2
    local targetName=(Options.TargetPart and Options.TargetPart.Value) or "Head"
    local camPos=camera.CFrame.Position
    local lookDir=camera.CFrame.LookVector
    local my_team=get_team(local_player)
    local bestPart=nil; local minFOVDist=math.huge

    local function evaluate(actor, id)
        if not is_alive(actor) then return end
        local model=actor.Character
        if not model or model==local_player.Character then return end
        local cache=actor._CachedParts
        local primary=(cache and cache.Primary) or model.PrimaryPart or get_part(model,"Head")
        if not primary then return end
        local offset=primary.Position-camPos
        if offset:Dot(lookDir)<0 or offset:Dot(offset)>2250000 then return end
        if Toggles.TeamCheck and Toggles.TeamCheck.Value then
            local tp=(typeof(id)=="number" and players:GetPlayerByUserId(id)) or actor.Owner
            if tp and get_team(tp)==my_team then return end
        end
        local part=(cache and cache[targetName]) or get_part(model,targetName) or (cache and cache.Head) or primary
        if not part then return end
        local pos,onScreen=camera:WorldToViewportPoint(part.Position)
        if onScreen then
            local fovDist=(Vector2.new(pos.X,pos.Y)-screenCenter):Dot(Vector2.new(pos.X,pos.Y)-screenCenter)
            if fovDist<maxFOVSqr and fovDist<minFOVDist and is_visible(part) then
                minFOVDist=fovDist; bestPart=part
            end
        end
    end

    for _,p in ipairs(players:GetPlayers()) do
        if p~=local_player then
            local a=get_actor_from_player(p)
            if a then evaluate(a, p.UserId) end
        end
    end
    for a in pairs(actor_list) do
        if not (a.Owner and a.Owner:IsA("Player")) then evaluate(a,a) end
    end
    CurrentSilentAimTarget=bestPart
end

