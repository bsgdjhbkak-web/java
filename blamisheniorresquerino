local function GetESPFolder()
    if current_esp_folder and current_esp_folder.Parent then return current_esp_folder end
    current_esp_folder=nil
    for _,o in pairs(esp_pool) do if o.box then o.box:Destroy() end end; table.clear(esp_pool)
    for _,o in pairs(esp_objects) do if o.box then o.box:Destroy() end end; table.clear(esp_objects)
    local f=Instance.new("Folder"); f.Name="cumyin_ESP"
    local done=false
    if gethui then pcall(function() f.Parent=gethui(); done=true end) end
    if not done then pcall(function() f.Parent=game:GetService("CoreGui"); done=true end) end
    if not done then
        local pg=local_player:FindFirstChild("PlayerGui")
        if pg then f.Parent=pg end
    end
    current_esp_folder=f; return f
end

local function create_esp_group()
    local box=Instance.new("BoxHandleAdornment")
    box.Name="ESP_Box"; box.AlwaysOnTop=true; box.ZIndex=5; box.Transparency=0
    local folder=GetESPFolder()
    if folder then box.Parent=folder end
    return {box=box}
end

local function remove_esp(id)
    local objs=esp_objects[id]
    if objs then
        if objs.box then objs.box.Adornee=nil; objs.box.Visible=false end
        table.insert(esp_pool, objs); esp_objects[id]=nil
    end
end

local function init_esp_entry(id)
    if esp_objects[id] then return end
    local group=nil
    while #esp_pool>0 do
        local g=table.remove(esp_pool)
        if g and g.box and g.box.Parent then group=g; break
        elseif g and g.box then g.box:Destroy() end
    end
    if not group then group=create_esp_group() end
    if group then if group.box then group.box.Visible=false end; esp_objects[id]=group end
end

local function render_esp(id, actor, color, is_visible_toggle, maxDistSqr, dist_sqr)
    if not is_visible_toggle then if esp_objects[id] then remove_esp(id) end; return end
    local model=actor.Character
    if not model or not model.Parent or not is_alive(actor) then
        if esp_objects[id] then remove_esp(id) end; return
    end
    if dist_sqr>(maxDistSqr or 4000000) then if esp_objects[id] then remove_esp(id) end; return end
    if not esp_objects[id] then init_esp_entry(id) end
    local objs=esp_objects[id]
    if not objs then return end
    local box=objs.box
    if not box or not box.Parent then esp_objects[id]=nil; return end
    local root=model:FindFirstChild("Head") or model.PrimaryPart
    if root then
        box.Visible=true
        if box.Adornee~=root then box.Adornee=root end
        local targetSize=root.Size*1.2
        if (box.Size-targetSize).Magnitude>0.01 then box.Size=targetSize end
        box.AlwaysOnTop=true; box.ZIndex=5
        if objs._lastC~=color then box.Color3=color; objs._lastC=color end
    else
        box.Visible=false
    end
end

-- ============================================================
-- HITBOX EXPANDER with Yellow Highlight
-- ============================================================

local mt = getrawmetatable(game)
local old_index = mt.__index
setreadonly(mt, false)

mt.__index = newcclosure(function(t, k)
    if k == "Size" and ModifiedParts[t] then
        return OriginalSizes[t] or Vector3.new(1, 1, 1)
    end
    return old_index(t, k)
end)
setreadonly(mt, true)

local hitboxHighlights = {}

local function addHitboxHighlight(part)
    if not part or hitboxHighlights[part] then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "HitboxHighlight"
    highlight.FillColor = Color3.fromRGB(255, 255, 0) -- Yellow
    highlight.OutlineColor = Color3.fromRGB(255, 200, 0)
    highlight.FillTransparency = 0.7
    highlight.OutlineTransparency = 0.3
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = part.Parent or part
    
    hitboxHighlights[part] = highlight
end

local function removeHitboxHighlight(part)
    if hitboxHighlights[part] then
        pcall(function() hitboxHighlights[part]:Destroy() end)
        hitboxHighlights[part] = nil
    end
end

local function UpdateHitboxes()
    if not (Toggles.HitboxExpander and Toggles.HitboxExpander.Value) then
        -- Remove all highlights when disabled
        for part, hl in pairs(hitboxHighlights) do
            pcall(function() hl:Destroy() end)
        end
        table.clear(hitboxHighlights)
        
        -- Restore all hitbox sizes
        for part in pairs(ModifiedParts) do
            if part and part.Parent then
                part.Size = OriginalSizes[part]
                part.Transparency = 0
                part.CanCollide = true
            end
            ModifiedParts[part] = nil
        end
        return
    end
    
    local sizeVal = (Options.HitboxSize and Options.HitboxSize.Value) or 4
    local expansion = Vector3.new(sizeVal, sizeVal, sizeVal)
    local camPos = camera.CFrame.Position
    local myTeam = get_team(local_player)
    local teamCheck = Toggles.TeamCheck and Toggles.TeamCheck.Value

    local function expand(actor)
        local cache = actor._CachedParts
        local head = cache and cache.Head
        
        if not is_alive(actor) then
            if head and ModifiedParts[head] then
                head.Size = OriginalSizes[head]
                head.Transparency = 0
                head.CanCollide = true
                ModifiedParts[head] = nil
                removeHitboxHighlight(head)
            end
            return
        end
        
        if actor.Owner == local_player then return end
        
        -- Don't expand teammates if team check is on
        if teamCheck and actor.Owner and get_team(actor.Owner) == myTeam then
            if head and ModifiedParts[head] then
                head.Size = OriginalSizes[head]
                head.Transparency = 0
                head.CanCollide = true
                ModifiedParts[head] = nil
                removeHitboxHighlight(head)
            end
            return
        end
        
        if head and head:IsA("BasePart") then
            local offset = head.Position - camPos
            local distSqr = offset:Dot(offset)
            
            if distSqr < 25 or distSqr > 1000000 then
                if ModifiedParts[head] then
                    head.Size = OriginalSizes[head]
                    head.Transparency = 0
                    head.CanCollide = true
                    ModifiedParts[head] = nil
                    removeHitboxHighlight(head)
                end
                return
            end
            
            if not ModifiedParts[head] then
                ModifiedParts[head] = true
                OriginalSizes[head] = head.Size
                head.CanCollide = false
                head.Transparency = 0.4
                
                -- Add yellow highlight
                addHitboxHighlight(head)
            end
            if head.Size ~= expansion then head.Size = expansion end
            if head.CanCollide then head.CanCollide = false end
        end
    end
    
    for _, p in ipairs(players:GetPlayers()) do
        local actor = get_actor_from_player(p)
        if actor then expand(actor) end
    end
    for actor in pairs(actor_list) do expand(actor) end
end

task.spawn(function()
    while not IsUnloading do 
        pcall(UpdateHitboxes)
        task.wait(1)
    end
end)

