local rankViewerClone = nil

local function showRankCard(player)
    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if not pg then return end
    local rankFrame = nil
    for _, gui in ipairs(pg:GetChildren()) do
        if gui:IsA("ScreenGui") then
            rankFrame = gui:FindFirstChild("RankFrame", true)
                or gui:FindFirstChild("ProfileFrame", true)
                or gui:FindFirstChild("RankCard", true)
                or gui:FindFirstChild("PlayerCard", true)
            if rankFrame then break end
        end
    end
    if not rankFrame then return end
    if rankViewerClone and rankViewerClone.Parent then rankViewerClone:Destroy() end
    local clone = rankFrame:Clone()
    clone.Name = "cumyin_rankviewer"
    local nameLabel = clone:FindFirstChild("PlayerName", true) or clone:FindFirstChild("Username", true)
    local repLabel  = clone:FindFirstChild("Reputation", true) or clone:FindFirstChild("Rep", true)
    local rankLabel = clone:FindFirstChild("RankName", true) or clone:FindFirstChild("Rank", true)
    if nameLabel and nameLabel:IsA("TextLabel") then
        nameLabel.Text = player.DisplayName .. " (@" .. player.Name .. ")"
    end
    local ls = player:FindFirstChild("leaderstats")
    local repStat = ls and (ls:FindFirstChild("Reputation") or ls:FindFirstChild("Rep") or ls:FindFirstChild("rep"))
    local repVal  = repStat and repStat.Value or 0
    if repLabel and repLabel:IsA("TextLabel") then repLabel.Text = tostring(repVal) end
    if rankLabel and rankLabel:IsA("TextLabel") then
        local rName, rCol = getRepRank(repVal)
        rankLabel.Text = rName; rankLabel.TextColor3 = rCol
    end
    clone.Position = UDim2.new(0.5, 0, 0.5, 0)
    clone.AnchorPoint = Vector2.new(0.5, 0.5)
    clone.Visible = true; clone.ZIndex = 999
    clone.Parent = rankFrame.Parent
    rankViewerClone = clone
    task.delay(4, function()
        if rankViewerClone == clone and clone.Parent then
            clone:Destroy(); rankViewerClone = nil
        end
    end)
end

