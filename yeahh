-- Unique tag written onto modules we've already hooked, so we never mistake
-- a previously-hooked (now dead) module for a fresh one after respawn.
local HOOK_TAG = "_cumyin_hooked_" .. tostring(tick())

local function findBulletModule()
    -- Prefer a module whose newbullet is a plain function (not our hook, not tagged)
    for _, obj in ipairs(getgc(true)) do
        if type(obj) == "table" and
           rawget(obj, "bullets") ~= nil and
           rawget(obj, "newbullet") and type(rawget(obj, "newbullet")) == "function" and
           rawget(obj, "step") and rawget(obj, "clean") and
           rawget(obj, HOOK_TAG) == nil then  -- skip ones we already tagged
            return obj
        end
    end
    return nil
end

