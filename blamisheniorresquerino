-- ============================================================
-- BULK SCAN  (GC service finder — exact Mert Script logic)
-- ============================================================
local function BulkScan(retry)
    local now = tick()
    if not retry and gcCache and (now-lastScan)<45 then
        return {ReplicatorService=ReplicatorService, BulletService=BulletService}, lastScan
    end

    local ok, res = pcall(function() return filtergc("table") end)
    if not ok then ok,res = pcall(function() return getgc(true) end) end
    if not ok or type(res)~="table" then return {},{} end

    gcCache = res; lastScan = now
    local found = {}
    local collections = {FirearmInventoryClass={}, FirearmInventoryReplicator={}, FirearmInventory={}, TurretController={}}
    local count = 0

    for _, obj in pairs(res) do
        count=count+1
        if count%10000==0 then task.wait() end
        if type(obj)=="table" then
            if not ReplicatorService and not found.ReplicatorService and rawget(obj,"Actors") and rawget(obj,"LocalActor") then found.ReplicatorService=obj end
            if not BulletService     and not found.BulletService     and rawget(obj,"_multithreadSend") then found.BulletService=obj end
            if not WorldService      and not found.WorldService      and rawget(obj,"InactiveWorld")    then found.WorldService=obj end
            if not ClientService     and not found.ClientService     and rawget(obj,"Clients") and rawget(obj,"LocalClient") then found.ClientService=obj end
            if not VehicleService    and not found.VehicleService    and rawget(obj,"Vehicles") and rawget(obj,"Changed") then found.VehicleService=obj end
            if not EnvironmentService and not found.EnvironmentService and rawget(obj,"RainDensity") then found.EnvironmentService=obj end
            if not InventoryService  and not found.InventoryService  and rawget(obj,"Inventories") and rawget(obj,"_droppedItems") then found.InventoryService=obj end
            if not CalibersTable     and not found.CalibersTable     and rawget(obj,"shotgun_12gauge_00buck") then found.CalibersTable=obj end
            if not Network           and not found.Network           and rawget(obj,"_key") and type(rawget(obj,"_key"))=="table" and rawget(obj,"_code") then found.Network=obj end
            if not ControllerService and not found.ControllerService and rawget(obj,"Controller")~=nil then
                local ok2,hSim = pcall(function() return type(obj.Simulated)=="function" end)
                if ok2 and hSim then found.ControllerService=obj
                elseif type(obj.Controller)=="table" and rawget(obj.Controller,"Update") then found.ControllerService=obj end
            end
            if not CharacterController and not found.CharacterController and rawget(obj,"SetCFrame") and rawget(obj,"SetVehicleGoal") then
                if rawget(obj,"__index")==obj or not rawget(obj,"Parent") then found.CharacterController=obj end
            end
            if not FirearmInventoryClass and not found.FirearmInventoryClass and rawget(obj,"Equip") and rawget(obj,"Unequip") and rawget(obj,"Discharge") then found.FirearmInventoryClass=obj end
            if not Recoiler and not found.Recoiler and rawget(obj,"Impulse") and rawget(obj,"TimeSkip") and rawget(obj,"GetCameraAdjustment") then found.Recoiler=obj end
            if not ActorClass and not found.ActorClass and rawget(obj,"Update") and rawget(obj,"Vault") and rawget(obj,"Slide") then found.ActorClass=obj end
            if not CharacterCamera and not found.CharacterCamera and rawget(obj,"Update") and rawget(obj,"Render") and rawget(obj,"Watch") then found.CharacterCamera=obj end
            if not TurretController and not found.TurretController and rawget(obj,"_discharge") and rawget(obj,"Discharge") then found.TurretController=obj end
            if not GroundController and not found.GroundController and rawget(obj,"_toggleEngine") and rawget(obj,"_toggleIndicator") then found.GroundController=obj end
            if not HelicopterController and not found.HelicopterController and rawget(obj,"_toggleEngine") and rawget(obj,"_toggleSteerMode") and not rawget(obj,"_toggleIndicator") then found.HelicopterController=obj end

            if rawget(obj,"_firearm") and rawget(obj,"_actor") then table.insert(collections.FirearmInventoryReplicator,obj)
            elseif rawget(obj,"_firearm") and rawget(obj,"_bulletsShot") then table.insert(collections.FirearmInventory,obj)
            elseif rawget(obj,"_turret") and rawget(obj,"_config") then table.insert(collections.TurretController,obj) end
        end
    end

    -- Assign globals
    ReplicatorService   = found.ReplicatorService   or ReplicatorService
    BulletService       = found.BulletService       or BulletService
    WorldService        = found.WorldService        or WorldService
    ClientService       = found.ClientService       or ClientService
    VehicleService      = found.VehicleService      or VehicleService
    EnvironmentService  = found.EnvironmentService  or EnvironmentService
    InventoryService    = found.InventoryService    or InventoryService
    CalibersTable       = found.CalibersTable       or CalibersTable
    CharacterController = found.CharacterController or CharacterController
    ControllerService   = found.ControllerService   or ControllerService
    FirearmInventoryClass=found.FirearmInventoryClass or FirearmInventoryClass
    Recoiler            = found.Recoiler            or Recoiler
    ActorClass          = found.ActorClass          or ActorClass
    TurretController    = found.TurretController    or TurretController
    GroundController    = found.GroundController    or GroundController
    HelicopterController= found.HelicopterController or HelicopterController
    CharacterCamera     = found.CharacterCamera     or CharacterCamera
    Network             = found.Network             or Network

    FirearmInventory = collections.FirearmInventory
    WeaponManager.Visuals = collections.FirearmInventoryReplicator
    WeaponManager.Logic   = collections.FirearmInventory

    return found, collections
end

