-- CHARACTER BOUNDS
-- ============================================================
-- Scans only the named humanoid body parts (never hitbox/weapon parts)
-- so hitbox expander can't inflate the box. Uses the on-flag from
-- WorldToViewportPoint so off-screen players are correctly hidden.
local HUMANOID_PARTS = {
    "Head","Torso","HumanoidRootPart",
    "Left Arm","Right Arm","Left Leg","Right Leg",
    "UpperTorso","LowerTorso","LeftUpperArm","RightUpperArm",
    "LeftLowerArm","RightLowerArm","LeftHand","RightHand",
    "LeftUpperLeg","RightUpperLeg","LeftLowerLeg","RightLowerLeg",
    "LeftFoot","RightFoot",
}
local function getCharacterBounds(character)
    local root = character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart
    local inLighting = character:IsDescendantOf(Lighting)
    if inLighting then
        -- in-car: fixed small box around HRP
        if not root then return nil end
        local pos = root.Position
        return { Position=pos, Min=pos-Vector3.new(1.5,3,1), Max=pos+Vector3.new(1.5,0.5,1) }
    end
    local minX,minY,minZ = math.huge,math.huge,math.huge
    local maxX,maxY,maxZ = -math.huge,-math.huge,-math.huge
    local found = 0
    for _, name in ipairs(HUMANOID_PARTS) do
        local part = character:FindFirstChild(name)
        if part and part:IsA("BasePart") then
            local p, s = part.Position, part.Size/2
            for _,cv in ipairs({
                p+Vector3.new( s.X, s.Y, s.Z), p+Vector3.new( s.X, s.Y,-s.Z),
                p+Vector3.new( s.X,-s.Y, s.Z), p+Vector3.new( s.X,-s.Y,-s.Z),
                p+Vector3.new(-s.X, s.Y, s.Z), p+Vector3.new(-s.X, s.Y,-s.Z),
                p+Vector3.new(-s.X,-s.Y, s.Z), p+Vector3.new(-s.X,-s.Y,-s.Z),
            }) do
                minX=math.min(minX,cv.X) minY=math.min(minY,cv.Y) minZ=math.min(minZ,cv.Z)
                maxX=math.max(maxX,cv.X) maxY=math.max(maxY,cv.Y) maxZ=math.max(maxZ,cv.Z)
            end
            found += 1
        end
    end
    if found == 0 then
        if root then return {Position=root.Position, Min=root.Position-Vector3.new(2,3,1), Max=root.Position+Vector3.new(2,3,1)} end
        return nil
    end
    return {
        Position = Vector3.new((minX+maxX)/2,(minY+maxY)/2,(minZ+maxZ)/2),
        Min = Vector3.new(minX,minY,minZ),
        Max = Vector3.new(maxX,maxY,maxZ),
    }
end

-- ============================================================
-- FOV VISUAL RADIUS SCALING
-- ============================================================
-- CALIBRATED_FOV: FOV the slider was designed/tested at (game default 70).
-- Scale the raw pixel radius by tan ratio so the circle matches at any FOV.
-- We read Camera.FieldOfView directly — it's already being set from the slider
-- every frame in the render loop, so this is always current.
local CALIBRATED_FOV = 70
local function getVisualRadius(rawRadius)
    local fov = Camera.FieldOfView  -- always live, set by render loop from slider
    local scale = math.tan(math.rad(fov / 2)) / math.tan(math.rad(CALIBRATED_FOV / 2))
    return rawRadius * scale
end

-- ============================================================
-- TARGET DETECTION
-- ============================================================
-- Model cache for SA FOV — refreshed every 6 frames (~0.1s), avoids
-- pcall/getModel overhead on every single frame.
local saModelCache = {}
local saModelFrame = 0

local function getTargetInFOV(radius)
    local mousePos = UserInputService:GetMouseLocation()
    local closest, closestDist = nil, math.huge

    -- Refresh model cache every 6 frames
    saModelFrame += 1
    if saModelFrame >= 6 then
        saModelFrame = 0
        for _, p in pairs(Players:GetPlayers()) do
            if p == LocalPlayer then continue end
            local ok, m = pcall(function() return getModel:Invoke(p) end)
            saModelCache[p] = (ok and m) or nil
        end
        -- purge disconnected
        for p in pairs(saModelCache) do
            if not p.Parent then saModelCache[p] = nil end
        end
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local model = saModelCache[p]
        if not model then continue end
        local humanoid = model:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end
        -- Use HRP only — single WorldToViewportPoint call per player
        local root = model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart
        if not root then continue end
        local sp = Camera:WorldToViewportPoint(root.Position)
        if sp.Z <= 0 then continue end
        local d = (Vector2.new(sp.X, sp.Y) - mousePos).Magnitude
        if d <= radius and d < closestDist then
            closestDist = d
            closest = p
        end
    end
    return closest
end

local function predictPosition(model, aimPart, origin, speed)
    local root = model:FindFirstChild("HumanoidRootPart") or aimPart
    local vel = root.AssemblyLinearVelocity or Vector3.zero
    if vel.Magnitude < 1 then return aimPart.Position end
    local t = (aimPart.Position - origin).Magnitude / speed
    return aimPart.Position + Vector3.new(vel.X, 0, vel.Z) * t
end

