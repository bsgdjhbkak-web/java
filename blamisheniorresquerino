local function UpdateESPForActor(uid, espData, frameId, cachedCfg, localSquad)
    local actor=espData.Actor; local drawings=espData.Drawing; if not drawings then return end
    espData.LastUpdate=frameId
    if not actor or not actor.Alive then RemoveESP(uid); return end

    local distance=actor.LOD_Distance or 9999
    local isVisible=actor.ViewportOnScreen or actor.OnScreen
    if actor._isInactive or distance>cachedCfg.MaxDistance or not isVisible then
        SetAllVisible(drawings,espData,false); return
    end
    if distance>1200 and frameId%6~=0 then return end
    if distance>600  and frameId%3~=0 then return end
    if distance>300  and frameId%2~=0 then return end

    local worldPos=actor.Position or (actor.RootPart and actor.RootPart.Position)
    if not worldPos then return end
    local screenPt,onScreen=Camera:WorldToViewportPoint(worldPos)
    if not onScreen then SetAllVisible(drawings,espData,false); return end

    SetAllVisible(drawings,espData,true)
    local sX,sY=screenPt.X,screenPt.Y

    -- box dimensions
    local height=6.0; local hState=actor.HeightState
    if hState==1 then height=4.0 elseif hState==2 then height=2.0 elseif hState==4 then height=3.0 end
    local topSP=Camera:WorldToViewportPoint(worldPos+Vector3_new(0,height*0.5,0))
    local botSP=Camera:WorldToViewportPoint(worldPos-Vector3_new(0,height*0.5,0))
    local scale=cachedCfg.BoxScale or 1
    local boxH=math_abs(botSP.Y-topSP.Y)*scale
    local boxW=boxH*0.6
    local bpX=sX-boxW*0.5; local bpY=sY-boxH*0.5
    local boxColor=cachedCfg.BoxColor or espData.Color

    -- BOX
    if cachedCfg.UseBoxESP then
        if cachedCfg.BoxStyle=="Corner" then
            drawings.Box.Visible=false; drawings.BoxOutline.Visible=false
            local cLen=(boxW<boxH and boxW or boxH)*0.25
            local c=drawings.Corners
            local rX=bpX+boxW; local bY=bpY+boxH
            local pts={
                {Vector2_new(bpX,bpY),Vector2_new(bpX+cLen,bpY)},
                {Vector2_new(bpX,bpY),Vector2_new(bpX,bpY+cLen)},
                {Vector2_new(rX,bpY),Vector2_new(rX-cLen,bpY)},
                {Vector2_new(rX,bpY),Vector2_new(rX,bpY+cLen)},
                {Vector2_new(bpX,bY),Vector2_new(bpX+cLen,bY)},
                {Vector2_new(bpX,bY),Vector2_new(bpX,bY-cLen)},
                {Vector2_new(rX,bY),Vector2_new(rX-cLen,bY)},
                {Vector2_new(rX,bY),Vector2_new(rX,bY-cLen)},
            }
            for i=1,8 do c[i].From=pts[i][1]; c[i].To=pts[i][2]; c[i].Color=boxColor; c[i].Visible=true end
        else
            for _,l in ipairs(drawings.Corners) do l.Visible=false end
            drawings.BoxOutline.Size=Vector2_new(boxW,boxH); drawings.BoxOutline.Position=Vector2_new(bpX,bpY); drawings.BoxOutline.Visible=true
            drawings.Box.Size=Vector2_new(boxW,boxH); drawings.Box.Position=Vector2_new(bpX,bpY); drawings.Box.Color=boxColor; drawings.Box.Visible=true
        end
    else
        drawings.Box.Visible=false; drawings.BoxOutline.Visible=false
        for _,l in ipairs(drawings.Corners) do l.Visible=false end
    end

    -- NAME
    if cachedCfg.ShowNames then
        local dynScale=math_clamp(boxH*0.016,0.5,1.0)
        local nSz=13*cachedCfg.TextScale*dynScale
        local displayName=actor.OwnerName
        if espData.EntityType=="Zombie" then
            local h=actor.Health
            if h and type(h)=="table" and h.Ability then
                local an={"Crippled","Slow","Normal","Sprinter"}
                displayName=an[h.Ability] or "Zombie"
            else displayName="Zombie" end
        elseif not displayName or displayName=="???" then displayName="AI" end
        drawings.Name.Text=displayName; drawings.Name.Position=Vector2_new(sX,bpY-(nSz+3))
        drawings.Name.Color=espData.Color; drawings.Name.Size=nSz; drawings.Name.Visible=true
    else drawings.Name.Visible=false end

    -- DISTANCE
    if cachedCfg.ShowDistance then
        local dynScale=math_clamp(boxH*0.016,0.5,1.0)
        local dSz=12*cachedCfg.TextScale*dynScale
        drawings.Distance.Text=string_format("[%dm]",math_floor(distance*0.28))
        drawings.Distance.Size=dSz
        drawings.Distance.Position=Vector2_new(sX,bpY+boxH+2)
        drawings.Distance.Visible=true
    else drawings.Distance.Visible=false end

    -- HEALTH BAR
    if cachedCfg.ShowHealth and actor.Health then
        local hPct=1
        local hp=actor.Health
        if type(hp)=="number" then hPct=math_clamp(hp*0.01,0,1) end
        local barColor=cachedCfg.HealthBarColor or Color3_new(0,1,0)
        if cachedCfg.UseHealthGradient then barColor=Color3_fromHSV(hPct*0.3,1,1) end
        local barH=boxH*hPct
        local barX=bpX-5
        drawings.HealthBarOutline.Size=Vector2_new(4,boxH+2); drawings.HealthBarOutline.Position=Vector2_new(barX-1,bpY-1); drawings.HealthBarOutline.Visible=true
        drawings.HealthBar.Size=Vector2_new(2,barH); drawings.HealthBar.Position=Vector2_new(barX,bpY+(boxH-barH))
        drawings.HealthBar.Color=barColor; drawings.HealthBar.Visible=true
    else drawings.HealthBar.Visible=false; drawings.HealthBarOutline.Visible=false end

    -- TRACERS
    if cachedCfg.UseTracers then
        local vp=Camera.ViewportSize
        drawings.Tracer.From=Vector2_new(vp.X*0.5,vp.Y); drawings.Tracer.To=Vector2_new(sX,bpY+boxH)
        drawings.Tracer.Color=espData.Color; drawings.Tracer.Visible=true
    else drawings.Tracer.Visible=false end

    -- HIGHLIGHT
    if cachedCfg.UseHighlight and not espData.Highlight and actor.Character then
        pcall(function()
            local h=Instance.new("Highlight")
            h.FillColor=espData.Color; h.FillTransparency=0.85
            h.OutlineColor=espData.Color; h.OutlineTransparency=0
            h.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
            h.Parent=actor.Character; espData.Highlight=h
        end)
    end
    if espData.Highlight then
        pcall(function() espData.Highlight.FillColor=espData.Color; espData.Highlight.OutlineColor=espData.Color end)
    end

    -- HITBOX EXPANDER WITH METATABLE SPOOFING
    if cachedCfg.HitboxExpander then
        local head = (actor.Parts and actor.Parts.Head) or (actor.Character and actor.Character:FindFirstChild("Head"))
        if head and head:IsA("BasePart") then
            -- Store original size if not already stored
            if not OriginalSizes[head] then 
                OriginalSizes[head] = head.Size 
            end
            -- Mark for spoofing (metatable will return original size when read)
            ModifiedParts[head] = true
            -- Actually expand the hitbox
            local sz = cachedCfg.HitboxSize or 4
            head.Size = Vector3_new(sz, sz, sz)
            head.Transparency = 0.5
            head.CanCollide = false
        end
    else
        -- Restore all hitboxes
        for part, origSize in pairs(OriginalSizes) do
            if part and part.Parent then 
                part.Size = origSize
                part.Transparency = 0
                part.CanCollide = true
            end
            OriginalSizes[part] = nil
            ModifiedParts[part] = nil
        end
    end
end

