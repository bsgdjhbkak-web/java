local function SetupHooks()
    pcall(SetupAggressiveHooks)

    local TC=CharacterController
    if not TC or not TC.Update then
        for _,obj in pairs(getgc(true)) do
            if type(obj)=="table" and rawget(obj,"Update") and rawget(obj,"SetCFrame") and rawget(obj,"_processNewPosition") then
                TC=obj; CharacterController=obj; break
            end
        end
    end

    if not TC or not TC.Update then return end
    EnableSpeedController()

    if not TC._originalUpdate then TC._originalUpdate=TC.Update end
    if not TC._originalProcessNewPosition then TC._originalProcessNewPosition=TC._processNewPosition end

    if TC._originalProcessNewPosition then
        TC._processNewPosition=function(self,nextPos,...)
            if Config.CharacterNoclip_Enabled or Config.Character_Fly then
                return nextPos,true,Vector3.new(0,1,0),nil
            end
            return TC._originalProcessNewPosition(self,nextPos,...)
        end
    end

    local OldUpdate=TC._originalUpdate
    TC.Update=function(self,viewInput,dt,...)
        local la=(ReplicatorService and ReplicatorService.LocalActor) or (self and self._localActor)
        if Config.Character_Fly and la and la.Alive then
            la.UseClient=true; la._lod=false; la._isInactive=false
            self.VelocityGravity=0; self.HeightState=0; self.IsGrounded=true
            if la.Rappelling then la.Rappelling=nil end
            local camCF=Camera.CFrame; local dir=Vector3_new(0,0,0)
            if UIS:IsKeyDown(Enum.KeyCode.W) then dir=dir+camCF.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.S) then dir=dir-camCF.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.D) then dir=dir+camCF.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.A) then dir=dir-camCF.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then dir=dir+Vector3_new(0,1,0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then dir=dir-Vector3_new(0,1,0) end
            local spd=tonumber(Config.Character_FlySpeed) or 50
            local sprint=UIS:IsKeyDown(Enum.KeyCode.LeftShift) and 2.5 or 1
            local deltaTime=type(dt)=="number" and dt or 0.016
            local nextPos=self._position+(dir*spd*sprint*deltaTime)
            self._position=nextPos; self._lastSafePosition=nextPos
            la.Position=nextPos; la.SimulatedPosition=nextPos
            local _,yRot=camCF:ToOrientation()
            la.CFrame=CFrame_new(nextPos)*CFrame.Angles(0,yRot,0); la.Orientation=yRot
            return
        elseif Config.CharacterNoclip_Enabled then
            self.VelocityGravity=0; self.IsGrounded=true
            if la and la.Rappelling then la.Rappelling=nil end
        end
        return OldUpdate(self,viewInput,dt,...)
    end

    -- Noclip persistent
    if getgenv().NoclipConnection then pcall(function() getgenv().NoclipConnection:Disconnect() end) end
    getgenv().NoclipConnection=RunService.Stepped:Connect(function()
        if Config.CharacterNoclip_Enabled or Config.Character_Fly then
            local la=ReplicatorService and ReplicatorService.LocalActor
            local char=la and la.Character
            if char then
                for _,p in pairs(char:GetDescendants()) do
                    if p:IsA("BasePart") then
                        p.CanCollide=false; p.CanTouch=false; p.CanQuery=false; p.Massless=true
                        p.AssemblyLinearVelocity=Vector3.new(); p.Velocity=Vector3.new()
                    end
                end
            end
        end
    end)
    table.insert(getgenv().BlackhawkESP_Connections, getgenv().NoclipConnection)
end

