    _cachedCfg.UseHighlight=Config.UseHighlight; _cachedCfg.TextScale=Config.TextScale or 1.0
    _cachedCfg.DynamicTextScaling=true; _cachedCfg.HitboxExpander=Config.HitboxExpander
    _cachedCfg.HitboxSize=Config.HitboxSize
end

local function UpdateESP()
    if not ESPEnabled and not Config.HitboxExpander then return end
    if not ActorManager.Initialized then return end
    CurrentFrameId=CurrentFrameId+1
    local lClient=ClientService and ClientService.LocalClient
    local localSquad=nil
    if type(lClient)=="table" and type(lClient.Squad)=="table" then localSquad=lClient.Squad end
    if CurrentFrameId-_cachedCfgFrame>=30 then RefreshCachedCfg(); _cachedCfgFrame=CurrentFrameId end
    local cachedCfg=_cachedCfg

    local function Process(list)
        for _,actor in ipairs(list) do
            if actor._cachedShow==false then if ESPElements[actor.UID] then RemoveESP(actor.UID) end; continue end
            local uid=actor.UID; if not uid then continue end
            if not ESPElements[uid] then
                local color=GetEntityColor(actor,actor._entityType,localSquad)
                ESPElements[uid]={Actor=actor,EntityType=actor._entityType,Color=color,Drawing=CreateDrawingESP(),_visible=nil}
            end
            local e=ESPElements[uid]
            if CurrentFrameId%30==0 then e.Color=GetEntityColor(actor,actor._entityType,localSquad) end
            UpdateESPForActor(uid,e,CurrentFrameId,cachedCfg,localSquad)
        end
    end
    Process(ActorManager.Enemies)
    Process(ActorManager.Teammates)

    if CurrentFrameId%5==0 then
        for uid,e in pairs(ESPElements) do
            local a=e.Actor
            if not a or not a.Alive or not a.Character or e.LastUpdate<CurrentFrameId-2 then RemoveESP(uid) end
        end
    end
end

