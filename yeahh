end

-- ============================================================
-- SOUND HELPER
-- ============================================================
local function playSound(idStr, pitch)
    pcall(function()
        local id = tostring(idStr):match("%d+") or ""
        if id == "" then return end
        local s = Instance.new("Sound")
        s.SoundId = "rbxassetid://" .. id
        s.Volume = 1
        s.PlaybackSpeed = pitch or 1
        s.Parent = workspace
        s:Play()
        game:GetService("Debris"):AddItem(s, 5)
    end)
end

-- Kill detection: watch local player's Kills leaderstat
local lastKills = 0
local function bindKillDetect()
    local ls = LocalPlayer:WaitForChild("leaderstats", 10)
    if not ls then return end
    local killStat = ls:WaitForChild("Player Kills", 10)
    if not killStat then return end
    lastKills = killStat.Value
    killStat.Changed:Connect(function(val)
        if val > lastKills then
            lastKills = val
            if Toggles.KillSoundEnabled and Toggles.KillSoundEnabled.Value then
                local id = Options.KillSoundID and Options.KillSoundID.Value or "130576622673706"
                local kpitch = tonumber(Options.KillSoundPitch and Options.KillSoundPitch.Value) or 0.2
                playSound(id, kpitch)
            end
        else
            lastKills = val
        end
    end)
end
task.spawn(bindKillDetect)

-- Hit detection: scan for Hit/Damage remotes on the server→client path
-- AND watch locked_player health drops after we shoot
local hitDebounce = 0

local function onHitDetected(targetName)
    if not (Toggles.HitSoundEnabled and Toggles.HitSoundEnabled.Value) then return end
    local id = Options.HitSoundID and Options.HitSoundID.Value or "78469882347907"
    local hpitch = tonumber(Options.HitSoundPitch and Options.HitSoundPitch.Value) or 0.2
    playSound(id, hpitch)
    pushNotification("hit: " .. (targetName or "target"))
end

-- Bind to Hitmark remote: fires with true=incoming (you got hit), nil=outgoing (you hit someone)
task.spawn(function()
    local remoteEvents = ReplicatedStorage:WaitForChild("RemoteEvents", 15)
    if not remoteEvents then return end
    local hitmark = remoteEvents:WaitForChild("Hitmark", 15)
    if not hitmark or not hitmark:IsA("RemoteEvent") then return end
    hitmark.OnClientEvent:Connect(function(incoming)
        if incoming == true then return end  -- skip: you got hit
        onHitDetected(locked_player and locked_player.Name or "target")
    end)
end)



