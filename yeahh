local undergroundActive = false
local undergroundThread = nil
local UNDERGROUND_DEPTH = 10

local function stopUnderground()
    undergroundActive = false
    if undergroundThread then
        pcall(function() task.cancel(undergroundThread) end)
        undergroundThread = nil
    end
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then root.Anchored = false end
end

local function runUndergroundLoop()
    undergroundActive = true
    while undergroundActive and Toggles.UndergroundEnabled and Toggles.UndergroundEnabled.Value do
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then
            root.Anchored = true
            root.CFrame = CFrame.new(root.Position.X, root.Position.Y - UNDERGROUND_DEPTH, root.Position.Z)
            task.wait(10)
            if not undergroundActive then root.Anchored = false; break end
            root.CFrame = CFrame.new(root.Position.X, root.Position.Y + UNDERGROUND_DEPTH, root.Position.Z)
            root.Anchored = false
            task.wait(3)
        else
            task.wait(1)
        end
    end
    undergroundActive = false
end

Toggles.UndergroundEnabled:OnChanged(function()
    if Toggles.UndergroundEnabled.Value then
        undergroundThread = task.spawn(runUndergroundLoop)
