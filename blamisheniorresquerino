-- MAIN RENDER LOOP
-- ============================================================
add_connection(run_service.RenderStepped:Connect(function()
    frame_id=frame_id+1
    local now=tick()
    local camPos=camera.CFrame.Position

    -- Update PlayerMap
    if now-last_pmap_upd>0.5 then
        local pm={}; for _,p in ipairs(players:GetPlayers()) do pm[p.Name]=p end
        PlayerNameMap=pm; last_pmap_upd=now
    end

    -- Refresh settings 10Hz
    if now-last_settings_tick>0.1 then
        local maxDist=(Options.MaxESPDistance and Options.MaxESPDistance.Value) or 2000
        f_settings.ESP       = Toggles.ESPEnabled and Toggles.ESPEnabled.Value
        f_settings.SA        = Toggles.SilentAimEnabled and Toggles.SilentAimEnabled.Value
        f_settings.Players   = Toggles.ShowPlayers and Toggles.ShowPlayers.Value
        f_settings.NPCs      = Toggles.ShowNPCs and Toggles.ShowNPCs.Value
        f_settings.Zombies   = Toggles.ShowZombies and Toggles.ShowZombies.Value
        f_settings.Teammates = Toggles.ShowTeammates and Toggles.ShowTeammates.Value
        f_settings.MaxDistSqr= maxDist*maxDist
        f_settings.TeamCheck = Toggles.TeamCheck and Toggles.TeamCheck.Value
        f_settings.AutoReload= Toggles.AutoReload and Toggles.AutoReload.Value
        colors_cache.enemy   = Options.EnemyColor and Options.EnemyColor.Value or Color3.new(1,0,0)
        colors_cache.team    = Options.TeamColor and Options.TeamColor.Value or Color3.new(0,1,0)
        colors_cache.npc     = Options.NPCColor and Options.NPCColor.Value or Color3.new(1,1,1)
        colors_cache.zombie  = Options.ZombieColor and Options.ZombieColor.Value or Color3.new(1,0.5,0)
        last_settings_tick=now
    end

    -- Auto reload
    if f_settings.AutoReload and getgenv().cumyin_CurrentFirearm and (now-last_gunmod_tick>0.2) then
        local w=getgenv().cumyin_CurrentFirearm
        if ((w._mag and (w._mag.Capacity or 0)==0) or not w._mag) and not w._reloading then
            local mags=w:_getMags(); if #mags>0 then w:_reload() end
        end
        last_gunmod_tick=now
    end

    -- Build active actors
    table.clear(active_actors); table.clear(handled)
    local my_team=get_team(local_player)

    for _,p in ipairs(CachedPlayers) do
        if p~=local_player then
            local actor=get_actor_from_player(p)
            if not actor and p.Character then
                if SimulatedActorCache[p] and SimulatedActorCache[p].Character==p.Character then
                    actor=SimulatedActorCache[p]
                else
                    local root=p.Character.PrimaryPart or p.Character:FindFirstChild("Head")
                    if root then
                        actor={Character=p.Character, Owner=p, Name=p.Name, Alive=true, _isSimulated=true,
                               _CachedParts={Head=p.Character:FindFirstChild("Head"),
                               UpperTorso=p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso"),
                               Primary=root}}
                        SimulatedActorCache[p]=actor
                    end
                end
            end
            if actor then active_actors[p.UserId]={actor=actor, name=p.Name} end
        end
    end

    for actor in pairs(actor_list) do
        if not IsUnloading then
            local model=actor.Character
            if not model or not model.Parent then actor_list[actor]=nil; continue end
            if actor.Owner and actor.Owner~=local_player then
                if not active_actors[actor.Owner.UserId] then
                    active_actors[actor.Owner.UserId]={actor=actor, name=actor.Owner.Name}
                end
            elseif not actor.Owner then
                local fp=PlayerNameMap[model.Name]
                if fp and fp~=local_player then
                    actor.Owner=fp
                    if not active_actors[fp.UserId] then
                        active_actors[fp.UserId]={actor=actor, name=fp.Name}
                    end
                else
                    active_actors[actor]={actor=actor, name=actor.Zombie and "Zombie" or "NPC"}
                end
            end
        end
    end

    -- SA scan + ESP render
    local sa_bestPart=nil; local sa_minFOVDist=math.huge
    local sa_maxFOVSqr=(Options.FOVRadius and Options.FOVRadius.Value or 400)^2
    local sa_screenCenter=camera.ViewportSize/2
    local sa_targetName=(Options.TargetPart and Options.TargetPart.Value) or "Head"
    local lookDir=camera.CFrame.LookVector

    for id, data in pairs(active_actors) do
        local ac=data.actor
        if not ac.Owner and typeof(id)=="number" then ac.Owner=players:GetPlayerByUserId(id) end
        if ac.Zombie or data.name=="Zombie" then ac._Category="Zombie"
        elseif ac.Owner or typeof(id)=="number" then ac._Category="Player"
        else ac._Category="NPC" end

        if not ac._CachedParts or (now-(ac._LastPartsUpdate or 0)>2) then update_cached_parts(ac) end

        local primary=ac._CachedParts and ac._CachedParts.Primary
        if not primary or not primary.Parent then continue end

        local offset=primary.Position-camPos
        local dist_sqr=offset:Dot(offset)

        -- ESP
        if f_settings.ESP then
            local is_teammate=false
            if f_settings.TeamCheck and ac._Category=="Player" then
                local team=get_team(ac.Owner)
                if team and my_team and team==my_team then is_teammate=true end
            end
            local color=colors_cache.enemy
            local visible=false
            if ac._Category=="Player" then
                visible=is_teammate and f_settings.Teammates or (not is_teammate and f_settings.Players)
                if is_teammate then color=colors_cache.team end
            elseif ac._Category=="Zombie" then visible=f_settings.Zombies; color=colors_cache.zombie
            else visible=f_settings.NPCs; color=colors_cache.npc end
            render_esp(id, ac, color, visible, f_settings.MaxDistSqr, dist_sqr)
        end

        handled[id]=true

        -- SA scan
        if f_settings.SA and is_alive(ac) then
            local is_enemy=true
            if f_settings.TeamCheck and ac._Category=="Player" then
                local team=get_team(ac.Owner)
                if team and my_team and team==my_team then is_enemy=false end
            end
            if is_enemy and offset:Dot(lookDir)>0 and dist_sqr<2250000 then
                local cache=ac._CachedParts
                local part=(cache and cache[sa_targetName]) or (cache and cache.Head) or (cache and cache.Primary)
                if part then
                    local pos,onScreen=camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local fovDist=(Vector2.new(pos.X,pos.Y)-sa_screenCenter).Magnitude^2
                        if fovDist<sa_maxFOVSqr and fovDist<sa_minFOVDist and is_visible(part) then
                            sa_minFOVDist=fovDist; sa_bestPart=part
                        end
                    end
                end
            end
        end
    end

    CurrentSilentAimTarget=sa_bestPart

    -- Cleanup stale ESP every 300 frames
    if frame_id%300==0 then
        for id in pairs(esp_objects) do if not handled[id] then remove_esp(id) end end
        for model in pairs(part_cache) do if not model.Parent then part_cache[model]=nil end end
    end
end))

