local function applyRainSetting()
    local ss = game:GetService("SoundService")
    local rain = ss:FindFirstChild("Rain")
    if rain and rain:IsA("Sound") then
        rain.Looped = not (Toggles.DisableRain and Toggles.DisableRain.Value)
        if Toggles.DisableRain and Toggles.DisableRain.Value then
            rain:Stop()
        end
