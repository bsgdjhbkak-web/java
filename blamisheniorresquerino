-- HOOK CONTROLLER  (GetMuzzleCFrame silent aim)
-- ============================================================
local function HookController(controller)
    if type(controller)~="table" or controller._hookedMuzzle then return end
    if rawget(controller,"_turret") then return end
    if not controller.GetMuzzleCFrame then return end

    controller._originalMuzzle = controller.GetMuzzleCFrame
    controller.GetMuzzleCFrame = function(self, ...)
        local muzzleCF,v2,v3 = controller._originalMuzzle(self,...)
        if not muzzleCF then return muzzleCF,v2,v3 end

        local combatTarget = ActorManager.SelectedTarget_RB or ActorManager.SelectedTarget_SA
        local targetActor  = ActorManager.SelectedActor_RB  or ActorManager.SelectedActor_SA

        if (Config.SilentAim or Config.RageMode) and combatTarget and targetActor then
            local targetPos = targetActor._visiblePoint or combatTarget.Position
            local muzzleVel = 2000
            if BulletService and self._firearm and self._firearm.Tune then
                local t=self._firearm.Tune
                local ok,vel=pcall(function() return BulletService:GetInfo(t.Caliber or t.CALIBER, t.Barrel or t.BARREL) end)
                if ok and vel then muzzleVel=vel end
            end
            local tVel=Vector3_new(0,0,0)
            if targetActor._oldDirection then tVel=targetActor._oldDirection*60
            elseif combatTarget.Parent and combatTarget.Parent.PrimaryPart then
                tVel=combatTarget.Parent.PrimaryPart.AssemblyLinearVelocity or Vector3_new(0,0,0)
            end
            local aimPos = SolveLead(muzzleCF.Position, targetPos, tVel, muzzleVel, 32.2)
            muzzleCF = CFrame_new(muzzleCF.Position, aimPos)
        end
        return muzzleCF,v2,v3
    end
    controller._hookedMuzzle=true
end

