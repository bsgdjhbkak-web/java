-- Item chams: keep a flat parts list (no originals table needed —
-- RS parts aren't rendered in world so we just set color each frame)
local itemChamParts     = {}   -- flat list refreshed every N frames
local itemChamScanFrame = 0
local armChamOriginals  = {}
local armRainbowHue     = 0

-- Collect parts from RS>Items folders
local function getItemParts()
    local parts = {}
    local items = ReplicatedStorage:FindFirstChild("Items")
    if not items then return parts end
    for _, folder in ipairs({"primary","secondary","melee","attachment"}) do
        local f = items:FindFirstChild(folder)
        if f then
            for _, desc in ipairs(f:GetDescendants()) do
                if desc:IsA("BasePart") or desc:IsA("UnionOperation") then
                    table.insert(parts, desc)
                end
            end
        end
    end
    return parts
end

-- Collect Left Arm / Right Arm from Camera>localmodel
local function getArmParts()
    local parts = {}
    local cam = workspace:FindFirstChild("Camera")
    if not cam then return parts end
    local lm = cam:FindFirstChild("localmodel")
    if not lm then return parts end
    for _, desc in ipairs(lm:GetDescendants()) do
        if (desc:IsA("BasePart") or desc:IsA("UnionOperation")) and
           (desc.Name == "Left Arm" or desc.Name == "Right Arm") then
            table.insert(parts, desc)
        end
    end
    return parts
end

local function saveOriginals(partsFunc, tbl)
    for k in pairs(tbl) do tbl[k] = nil end
    for _, p in ipairs(partsFunc()) do
        tbl[p] = { Color=p.Color, Material=p.Material, Transparency=p.Transparency }
    end
end

local function restoreOriginals(tbl)
    for part, orig in pairs(tbl) do
        if part and part.Parent then
            part.Color = orig.Color
            part.Material = orig.Material
            part.Transparency = orig.Transparency
        end
    end
    for k in pairs(tbl) do tbl[k] = nil end
end

Toggles.ItemChamEnabled:OnChanged(function()
    if Toggles.ItemChamEnabled.Value then
        -- Immediately scan so there's no delay on enable
        itemChamParts = getItemParts()
    else
        -- Reset material/color on all known parts back to ForceField off
        -- (parts are in RS so no need to restore originals, just clear list)
        for _, part in ipairs(itemChamParts) do
            if part and part.Parent then
                part.Material = Enum.Material.SmoothPlastic
                part.Color    = Color3.fromRGB(163, 162, 165)
            end
        end
        itemChamParts = {}
    end
end)

Toggles.ArmChamEnabled:OnChanged(function()
    if Toggles.ArmChamEnabled.Value then
        saveOriginals(getArmParts, armChamOriginals)
