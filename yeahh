-- ============================================================
-- hooked_newbullet is created ONCE and never reassigned.
-- It reads original_newbullet at call-time so it always calls
-- the correct underlying function even after respawns.
hooked_newbullet = function(tag, player, cf, speed, power, pellet, sniper, tracer)
    local orig = original_newbullet
    if not orig then
        -- safety: no original captured yet, do nothing
        return
    end

    if player == LocalPlayer then
        last_bullet_speed = speed
        if Toggles.TracerEnabled and Toggles.TracerEnabled.Value then
            drawTracer(cf.Position, cf.LookVector)
        end
    end

    if player ~= LocalPlayer then
        return orig(tag, player, cf, speed, power, pellet, sniper, tracer)
    end

    if not (Toggles.SilentAimEnabled and Toggles.SilentAimEnabled.Value) or not locked_player then
        return orig(tag, player, cf, speed, power, pellet, sniper, tracer)
    end

    local ok, newCF = pcall(buildAimCFrame, cf, speed)
    if ok and newCF then
        return orig(tag, player, newCF, speed, power, pellet, sniper, tracer)
    else
        if not ok then warn("sa err " .. tostring(newCF)) end
        return orig(tag, player, cf, speed, power, pellet, sniper, tracer)
    end
end

local function applyHook()
    if not bullet_module then return end

    local capturedOrig = rawget(bullet_module, "newbullet")
    -- If the module already has our hook written in, don't double-apply
    if capturedOrig == hooked_newbullet then return end

    rawset(bullet_module, HOOK_TAG, true)
    original_newbullet = capturedOrig
    bullet_module.newbullet = hooked_newbullet
    print("✅ Silent aim hook applied (orig=" .. tostring(capturedOrig) .. ")")
end

