Options.HitboxColor:OnChanged(function() if Toggles.HitboxEnabled and Toggles.HitboxEnabled.Value then updateHitboxes() end end)
Options.HitboxMaterial:OnChanged(function() if Toggles.HitboxEnabled and Toggles.HitboxEnabled.Value then updateHitboxes() end end)

