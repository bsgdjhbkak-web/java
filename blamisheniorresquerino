-- ============================================================
-- WALL CHECK  (Mert Script)
-- ============================================================
local VisCache    = {}
local VisRayParams= RaycastParams.new()
VisRayParams.FilterType      = Enum.RaycastFilterType.Exclude
VisRayParams.CollisionGroup  = "CharacterCast"
VisRayParams.IgnoreWater     = true
local VisFilterTable   = table.create(16)
local LastVisCacheClean= 0

local function IsVisible(targetActor, targetPart, origin, isPriority)
    if not targetPart or not targetPart.Parent then return false end
    local now = getgenv().LastTime or tick()
    local uid = targetActor.UID

    if now-LastVisCacheClean>2 then
        for k,v in pairs(VisCache) do if now-v.last>5 then VisCache[k]=nil end end
        LastVisCacheClean=now
    end

    if not isPriority then
        if VisCache[uid] and (now-VisCache[uid].last<0.05) then return VisCache[uid].result end
        if getgenv().RaycastBudget<=0 then return false end
        getgenv().RaycastBudget = getgenv().RaycastBudget-1
    end

    local originPos = origin or (getgenv().LastCamCF and getgenv().LastCamCF.Position or Camera.CFrame.Position)
    local character = targetPart.Parent
    table.clear(VisFilterTable)
    table.insert(VisFilterTable, Camera)
    if LocalPlayer.Character then table.insert(VisFilterTable, LocalPlayer.Character) end
    table.insert(VisFilterTable, character)
    VisRayParams.FilterDescendantsInstances = VisFilterTable

    local function CheckPoint(point)
        local dir = point-originPos
        local result = Workspace:Raycast(originPos, dir, VisRayParams)
        if not result then return true end
        if result.Instance:IsDescendantOf(character) then return true end
        if result.Instance.Transparency>0.9 or not result.Instance.CanCollide then return true end
        return false
    end

    local isVis = CheckPoint(targetPart.Position)
    VisCache[uid] = {result=isVis, last=now}
    if isVis then targetActor._visiblePoint=targetPart.Position end
    return isVis
end

-- ============================================================
-- BULLET PREDICTION
-- ============================================================
local function SolveLead(sourcePos, targetPos, targetVelocity, bulletSpeed, gravity)
    local distance = (targetPos-sourcePos).Magnitude
    local time     = distance/bulletSpeed
    local predicted = targetPos
    if targetVelocity and targetVelocity.Magnitude>0.1 then
        predicted = targetPos+(targetVelocity*time)
        time = (predicted-sourcePos).Magnitude/bulletSpeed
        predicted = targetPos+(targetVelocity*time)
    end
    predicted = predicted+Vector3_new(0, 0.5*gravity*(time*time), 0)
    return predicted, time
end

-- ============================================================
-- ACTOR MANAGER  (spatial partitioning, entity caching)
-- ============================================================
local function GetSectorKey(pos, sz)
    return math.floor(pos.X/sz)*65536 + math.floor(pos.Z/sz)
end
local function DecodeSectorKey(key)
    local x=math.floor(key/65536); local z=key-x*65536
    if z>32767 then z=z-65536 end
    return x,z
end

function ActorManager:Update()
    if not ReplicatorService or not ReplicatorService.Actors then
        if not self.Initialized then
            table.clear(self.Enemies); table.clear(self.Teammates); table.clear(self.Vehicles)
            self.Initialized=true
        end
        return
    end
    local now = tick()
    if not self._sectors then
        self._sectors={}; self._sectorSize=512; self._playerSector=nil
    end
    if not self._lastListUpdate or (now-self._lastListUpdate>0.5) then
        table.clear(self.Enemies); table.clear(self.Teammates); table.clear(self.Vehicles)
        table.clear(self._sectors)
        local localSquad=nil
        if ClientService and type(ClientService.LocalClient)=="table" then
            localSquad=ClientService.LocalClient.Squad
        end
        for _,actor in pairs(ReplicatorService.Actors) do
            if not actor or not actor.Alive or not actor.Character then continue end
            if actor.Owner==LocalPlayer then continue end
            actor._entityType=GetEntityType(actor)
            actor._isTeammate=IsTeammate(actor,localSquad)
            actor._cachedShow=ShouldShowEntity(actor,actor._entityType,localSquad)
            if actor._isTeammate then
                table.insert(self.Teammates,actor)
            else
                table.insert(self.Enemies,actor)
                local aPos=actor.Position or (actor.RootPart and actor.RootPart.Position)
                if aPos then
                    local sk=GetSectorKey(aPos,self._sectorSize)
                    if not self._sectors[sk] then self._sectors[sk]={} end
                    table.insert(self._sectors[sk],actor)
                end
            end
        end
        if VehicleService and VehicleService.Vehicles then
            for _,veh in pairs(VehicleService.Vehicles) do table.insert(self.Vehicles,veh) end
        end
        self._playerSector=GetSectorKey(Camera.CFrame.Position,self._sectorSize)
        self._lastListUpdate=now
        self.Initialized=true
    end
    -- target refresh 20Hz
    if self.Initialized and (not self._lastTargetUpdate or (now-self._lastTargetUpdate>0.05)) then
        if GetCombatTarget then
            if Config.SilentAim or Config.ShowPrediction then
                local t,a=GetCombatTarget("SilentAim")
                self.SelectedTarget_SA=t; self.SelectedActor_SA=a
            else self.SelectedTarget_SA=nil; self.SelectedActor_SA=nil end
        end
        self._lastTargetUpdate=now
    end
    -- ragebot 60Hz
    if self.Initialized and Config.RageMode and GetCombatTarget then
        if not self._lastRageUpdate or (now-self._lastRageUpdate>0.016) then
            local t,a=GetCombatTarget("Rage")
            self.SelectedTarget_RB=t; self.SelectedActor_RB=a
            self._lastRageUpdate=now
        end
    elseif not Config.RageMode then
        self.SelectedTarget_RB=nil; self.SelectedActor_RB=nil
    end
end

-- ============================================================
-- GET COMBAT TARGET  (Mert Script logic)
-- ============================================================
GetCombatTarget = function(mode)
    getgenv().RaycastBudget = (mode=="Rage") and 20 or 12
    local targetPartName = (mode=="Rage") and Config.Rage_TargetPart or Config.SilentAimTargetPart or "Head"
    local useFOV     = (mode=="SilentAim")
    local fovLimitSq = Config.SilentAimFOV^2
    local maxDistance= (mode=="Rage") and Config.Rage_Range or Config.MaxDistance or 2000
    local checkOrigin= GetMuzzlePosition() or Camera.CFrame.Position
    local mouseX, mouseY

    if not ActorManager.Enemies or #ActorManager.Enemies==0 then return nil,nil end

    if useFOV then
        local mp=UIS:GetMouseLocation(); mouseX,mouseY=mp.X,mp.Y
    end

    -- validate current ragebot target first
    if mode=="Rage" and ActorManager.SelectedActor_RB then
        local aa=ActorManager.SelectedActor_RB
        local ign=ActorManager._ignoredTargets
        if ign and ign[aa.UID] and tick()<ign[aa.UID] then
            ActorManager.SelectedActor_RB=nil; ActorManager.SelectedTarget_RB=nil
        elseif aa.Alive and aa.Character then
            local dist=aa.LOD_Distance or (aa.Position and (aa.Position-checkOrigin).Magnitude) or 9999
            if dist<=maxDistance then
                local part=aa.Parts and aa.Parts[targetPartName]
                if part and IsVisible(aa,part,checkOrigin,true) then return part,aa end
            end
            ActorManager.SelectedActor_RB=nil; ActorManager.SelectedTarget_RB=nil
        else
            ActorManager.SelectedActor_RB=nil; ActorManager.SelectedTarget_RB=nil
        end
    end

    local candidates = getgenv()._targetCandidates or table.create(64)
    table.clear(candidates); getgenv()._targetCandidates=candidates
    local now=tick()

    -- get enemy list (spatial for rage)
    local enemyList = ActorManager.Enemies
    if mode=="Rage" and ActorManager._sectors and ActorManager._playerSector then
        local el = getgenv()._cachedEnemyList or table.create(100)
        table.clear(el); getgenv()._cachedEnemyList=el
        local px,pz=DecodeSectorKey(ActorManager._playerSector)
        for dx=-1,1 do for dz=-1,1 do
            local k=(px+dx)*65536+(pz+dz)
            local se=ActorManager._sectors[k]
            if se then for _,a in ipairs(se) do table.insert(el,a) end end
        end end
        if #el>0 then enemyList=el end
    end

    for _,actor in pairs(enemyList) do
        if not actor.Alive then continue end
        local ign=ActorManager._ignoredTargets
        if ign and ign[actor.UID] then
            if now<ign[actor.UID] then continue
            else ign[actor.UID]=nil end
        end
        if not actor.Character then continue end
        local dist=actor.LOD_Distance
        if not dist or dist<=0 then
            local ap=actor.Position
            if not ap then local r=actor.RootPart or (actor.Parts and actor.Parts.Head); if not r then continue end; ap=r.Position end
            local d=ap-checkOrigin; dist=math.sqrt(d.X*d.X+d.Y*d.Y+d.Z*d.Z)
        end
        if dist>maxDistance then continue end
        local score=dist
        if useFOV then
            if not actor.ViewportOnScreen and dist>50 then continue end
            local rp=actor.Position or (actor.RootPart and actor.RootPart.Position)
            if not rp then continue end
            local pos,onScreen=Camera:WorldToViewportPoint(rp)
            if not onScreen then continue end
            local dx=pos.X-mouseX; local dy=pos.Y-mouseY
            local sdSq=dx*dx+dy*dy
            if sdSq>fovLimitSq then continue end
            score=sdSq
        end
        table.insert(candidates,{actor=actor,score=score,char=actor.Character,dist=dist})
    end

    if #candidates==0 then return nil,nil end

    -- linear min scan
    local bestIdx,bestScore=1,candidates[1].score
    for ci=2,#candidates do if candidates[ci].score<bestScore then bestScore=candidates[ci].score; bestIdx=ci end end
    if bestIdx~=1 then candidates[1],candidates[bestIdx]=candidates[bestIdx],candidates[1] end

    for i=1,#candidates do
        local c=candidates[i]; local actor=c.actor
        local part=(actor.Parts and actor.Parts[targetPartName])
            or (actor.Parts and (actor.Parts.Head or actor.Parts.UpperTorso))
            or (c.char and c.char:FindFirstChild("Head"))
        if part and part.Parent then
            if IsVisible(actor,part,checkOrigin) then return part,actor end
            if getgenv().RaycastBudget<=0 then break end
        end
    end
    return nil,nil
end

