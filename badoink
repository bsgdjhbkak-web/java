-- ZERO RECOIL
-- ============================================================
RunService:BindToRenderStep("ZeroRecoil", Enum.RenderPriority.Camera.Value + 10, function()
    if not (Toggles.ZeroRecoil and Toggles.ZeroRecoil.Value) then
        local p, y = Camera.CFrame:ToEulerAnglesYXZ()
        prevPitch, prevYaw = p, y; return
    end
    -- Aimlock owns pitch when active — don't fight it
    if aimlock_active then
        local p, y = Camera.CFrame:ToEulerAnglesYXZ()
        prevPitch, prevYaw = p, y; return
    end
    local pitch, yaw, roll = Camera.CFrame:ToEulerAnglesYXZ()
    local mouseDelta = UserInputService:GetMouseDelta()
    local recoilAmount = (pitch - prevPitch) - (-mouseDelta.Y * 0.00872)
    if math.abs(recoilAmount) > 0.0001 then
        local corrected = pitch - recoilAmount
        Camera.CFrame = CFrame.new(Camera.CFrame.Position) * CFrame.fromEulerAnglesYXZ(corrected, yaw, roll)
        prevPitch = corrected
    else
        prevPitch = pitch
    end
    prevYaw = yaw
end)

-- ============================================================
-- AIM LOCK
-- ============================================================
RunService:BindToRenderStep("AimLock", Enum.RenderPriority.Camera.Value + 1, function()
    aimLine.Visible = false
    if not (Toggles.AimLockEnabled and Toggles.AimLockEnabled.Value) then aimlock_active = false; return end
    if Toggles.AimLockRightClick and Toggles.AimLockRightClick.Value then
        if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then return end
    end
    local alFOV = Options.AimLockFOV and Options.AimLockFOV.Value or 150
    local target = getTargetInFOV(alFOV)
    if not target then aimlock_active = false; return end
    aimlock_active = true
    local model = getModel:Invoke(target)
    if not model then return end
    local partName = Options.AimLockPart and Options.AimLockPart.Value or 'Torso'
    local aimPart = model:FindFirstChild(partName)
        or model:FindFirstChild("Torso") or model:FindFirstChild("Head") or model.PrimaryPart
    if not aimPart then return end
    local smooth = Options.AimLockSmooth and Options.AimLockSmooth.Value or 4
    local curPitch, curYaw, curRoll = Camera.CFrame:ToEulerAnglesYXZ()
    local camPos = Camera.CFrame.Position
    local toTarget = aimPart.Position - camPos

    -- Yaw
    local targetYaw = math.atan2(-toTarget.X, -toTarget.Z)
    local yawDiff = targetYaw - curYaw
    if yawDiff > math.pi then yawDiff -= 2*math.pi end
    if yawDiff < -math.pi then yawDiff += 2*math.pi end
    local newYaw = curYaw + yawDiff * (1/smooth)

    -- Pitch — calculate the angle to the target part and lerp toward it
    local targetPitch = math.atan2(-toTarget.Y, Vector2.new(toTarget.X, toTarget.Z).Magnitude) * -1
    local pitchDiff = targetPitch - curPitch
    if pitchDiff > math.pi then pitchDiff -= 2*math.pi end
    if pitchDiff < -math.pi then pitchDiff += 2*math.pi end
    local newPitch = curPitch + pitchDiff * (1/smooth)

    Camera.CFrame = CFrame.new(camPos) * CFrame.fromEulerAnglesYXZ(newPitch, newYaw, curRoll)
    if Toggles.AimLockLine and Toggles.AimLockLine.Value then
        local partSP, partOn = Camera:WorldToViewportPoint(aimPart.Position)
        if partOn and partSP.Z > 0 then
            local mousePos = UserInputService:GetMouseLocation()
            aimLine.Visible = true
            aimLine.From = Vector2.new(partSP.X, partSP.Y)
            aimLine.To = mousePos
        end
    end
end)

-- ============================================================
-- PART DELETER
-- ============================================================
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode ~= Enum.KeyCode.LeftAlt then return end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        if #deletedParts > 0 then
            local last = table.remove(deletedParts)
            if last.instance and last.parent then
                last.instance.Parent = last.parent
                if last.cframe and last.instance:IsA("BasePart") then
                    last.instance.CFrame = last.cframe
                end
            end
        end
    else
        local tgt = LocalPlayer:GetMouse().Target
        if tgt then
            table.insert(deletedParts, {instance=tgt, parent=tgt.Parent, cframe=tgt:IsA("BasePart") and tgt.CFrame or nil})
            tgt.Parent = nil
        end
    end
end)

-- ============================================================
-- MAIN RENDER LOOP
-- ============================================================
local frameCount = 0
RunService.RenderStepped:Connect(function(dt)
    frameCount += 1
    updateWatermark(dt)
    -- FOV enforce
    local targetFOV = Options.CustomFOV and Options.CustomFOV.Value or 70
    if Camera.FieldOfView ~= targetFOV then Camera.FieldOfView = targetFOV end

    -- Ambiance enforce (loop so game can't override)
    if Toggles.NoFog and Toggles.NoFog.Value then
        if Lighting.FogEnd < 1e5 then Lighting.FogEnd=1e6; Lighting.FogStart=1e6 end
    end
    if Toggles.FullBright and Toggles.FullBright.Value then
        if Lighting.Ambient ~= Color3.new(1,1,1) then
            Lighting.Ambient=Color3.new(1,1,1); Lighting.OutdoorAmbient=Color3.new(1,1,1); Lighting.Brightness=2
        end
    end
    if Toggles.CustomLighting and Toggles.CustomLighting.Value then
        local wA = Options.AmbientColor and Options.AmbientColor.Value or originalAmbient
        local wO = Options.OutdoorAmbientColor and Options.OutdoorAmbientColor.Value or originalOutdoorAmbient
        local wF = Options.FogColor and Options.FogColor.Value or originalFogColor
        local wB = Options.LightingBrightness and (Options.LightingBrightness.Value/100) or originalBrightness
        if Lighting.Ambient ~= wA then Lighting.Ambient=wA end
        if Lighting.OutdoorAmbient ~= wO then Lighting.OutdoorAmbient=wO end
        if Lighting.FogColor ~= wF then Lighting.FogColor=wF end
        if Lighting.Brightness ~= wB then Lighting.Brightness=wB end
    end

    if frameCount % 10 == 0 and Toggles.HitboxEnabled and Toggles.HitboxEnabled.Value then
        updateHitboxes()
    end

    -- ======================================================
    -- FLY RENDER
    -- ======================================================
    local flyEnabled = Toggles.FlyEnabled and Toggles.FlyEnabled.Value

    -- Check if Space has been held long enough to activate
    if flyEnabled and not flying and flySpaceHoldStart then
        if (tick() - flySpaceHoldStart) >= 0.1 then
            activateFly()
        end
    end

    if flying then
        local character = LocalPlayer.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        local humanoid = character and character:FindFirstChild("Humanoid")

        if rootPart and humanoid and flyBodyVelocity and flyBodyGyro then
            humanoid.PlatformStand = true
            flyBodyGyro.CFrame = Camera.CFrame

            local moveVector = Vector3.zero
            local cf = Camera.CFrame

            -- WASD movement
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVector += cf.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVector -= cf.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVector -= cf.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVector += cf.RightVector end

            -- Space held = stay up (counteract gravity sink)
            -- Space released triggers deactivateFly via InputEnded, so here we
            -- just provide upward push while Space is down during flight
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                moveVector += Vector3.new(0, 1, 0)
            else
                -- Gravity sink when not pressing Space (will be brief as release = deactivate)
                moveVector -= Vector3.new(0, 1, 0)
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Q) then
                moveVector -= Vector3.new(0, 1, 0)
            end

            -- Mobile joystick horizontal
            local mobileMove = humanoid.MoveDirection
            if mobileMove.Magnitude > 0 then
                moveVector += Vector3.new(mobileMove.X, 0, mobileMove.Z)
            end

            local flySpeed = Options.FlySpeed and Options.FlySpeed.Value or 50
            if moveVector.Magnitude > 0 then
                flyBodyVelocity.Velocity = moveVector.Unit * flySpeed
            else
                flyBodyVelocity.Velocity = Vector3.zero
            end
        end
    end

    -- ======================================================
    -- SPEED HACK (velocity-based, never sets WalkSpeed)
    -- ======================================================
    do
        local speedOn = Toggles.SpeedEnabled and Toggles.SpeedEnabled.Value
        local speedChar = LocalPlayer.Character
        local speedHum  = speedChar and speedChar:FindFirstChild("Humanoid")
        local speedRoot = speedChar and speedChar:FindFirstChild("HumanoidRootPart")

        if not speedOn or not speedHum or not speedRoot or flying then
            -- disabled or flying — destroy movers if they exist
            if speedBV or speedLV then cleanupSpeed() end
        else
            local moveDir = speedHum.MoveDirection  -- unit vector set by engine from WASD/joystick
            local spd = Options.SpeedValue and Options.SpeedValue.Value or 32

            -- Prefer LinearVelocity (R15, undetected by typical WalkSpeed checks)
            -- Fall back to BodyVelocity (R6 / older games)
            local useLinear = pcall(function() return Instance.new("LinearVelocity") end)

            if useLinear then
                -- LinearVelocity with Plane mode — only controls XZ, Y is completely free
                if not speedLV or not speedLV.Parent then
                    cleanupSpeed()
                    speedAttachment = Instance.new("Attachment")
                    speedAttachment.Position = Vector3.zero
                    speedAttachment.Parent = speedRoot
                    speedLV = Instance.new("LinearVelocity")
                    speedLV.Attachment0 = speedAttachment
                    speedLV.VelocityConstraintMode = Enum.VelocityConstraintMode.Plane
                    speedLV.MaxForce = math.huge
                    speedLV.RelativeTo = Enum.ActuatorRelativeTo.World
                    speedLV.PlaneVelocity = Vector2.new(0, 0)
                    speedLV.PrimaryTangentAxis = Vector3.new(1, 0, 0)
                    speedLV.SecondaryTangentAxis = Vector3.new(0, 0, 1)
                    speedLV.Parent = speedRoot
                end
                -- Plane mode: X = world X axis velocity, Y = world Z axis velocity
                if moveDir.Magnitude > 0.1 then
                    speedLV.PlaneVelocity = Vector2.new(moveDir.X * spd, moveDir.Z * spd)
                else
                    speedLV.PlaneVelocity = Vector2.new(0, 0)
                end
            else
                -- BodyVelocity fallback — MaxForce Y=0 so gravity/jump are untouched
                if not speedBV or not speedBV.Parent then
                    cleanupSpeed()
                    speedBV = Instance.new("BodyVelocity")
                    speedBV.MaxForce = Vector3.new(1e5, 0, 1e5)
                    speedBV.P = 1e4
                    speedBV.Parent = speedRoot
                end
                if moveDir.Magnitude > 0.1 then
                    speedBV.Velocity = Vector3.new(moveDir.X * spd, 0, moveDir.Z * spd)
                else
                    speedBV.Velocity = Vector3.zero
                end
            end
        end
    end

    -- ======================================================
    -- ESP
    -- ======================================================
    local espOn      = Toggles.ESPEnabled and Toggles.ESPEnabled.Value
    local showBoxes  = Toggles.ESPBoxes and Toggles.ESPBoxes.Value
    local showNames  = Toggles.ESPNames and Toggles.ESPNames.Value
    local showDist   = Toggles.ESPDistance and Toggles.ESPDistance.Value
    local showHealth = Toggles.ESPHealth and Toggles.ESPHealth.Value
    local visCheck   = Toggles.ESPVisibleCheck and Toggles.ESPVisibleCheck.Value
    local thickness  = Options.ESPThickness and Options.ESPThickness.Value or 1
    local boxColor   = Options.ESPBoxColor and Options.ESPBoxColor.Value or Color3.fromRGB(255,182,193)
    local visColor   = Options.ESPVisibleColor and Options.ESPVisibleColor.Value or Color3.fromRGB(255,255,255)
    local myChar     = LocalPlayer.Character
    local myRoot     = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local useDisplay = Toggles.ESPDisplayName and Toggles.ESPDisplayName.Value

    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        local ok, character = pcall(function() return getModel:Invoke(player) end)
        if not ok or not character then
            if espBoxes[player] then removeESPBox(espBoxes[player]); espBoxes[player]=nil end
            espRayParams[player] = nil
            continue
        end

        local inLighting = character:IsDescendantOf(Lighting)
        local inWorld = character:IsDescendantOf(workspace)
        if not inWorld and not inLighting then
            if espBoxes[player] then removeESPBox(espBoxes[player]); espBoxes[player]=nil end
            espRayParams[player] = nil
            continue
        end

        local humanoid = character:FindFirstChild("Humanoid")
        if not humanoid then
            if espBoxes[player] then hideESPBox(espBoxes[player]) end
            continue
        end

        if not espBoxes[player] then espBoxes[player] = createESPBox() end
        local box = espBoxes[player]
        if not espOn then hideESPBox(box); continue end

        local statusLabel = inLighting and "In Car" or nil
        local bounds = getCharacterBounds(character)
        if not bounds then hideESPBox(box); continue end

        -- project all 8 corners — only count corners the viewport says are on-screen
        local corners = {
            bounds.Max,
            Vector3.new(bounds.Max.X, bounds.Max.Y, bounds.Min.Z),
            Vector3.new(bounds.Max.X, bounds.Min.Y, bounds.Max.Z),
            Vector3.new(bounds.Max.X, bounds.Min.Y, bounds.Min.Z),
            Vector3.new(bounds.Min.X, bounds.Max.Y, bounds.Max.Z),
            Vector3.new(bounds.Min.X, bounds.Max.Y, bounds.Min.Z),
            Vector3.new(bounds.Min.X, bounds.Min.Y, bounds.Max.Z),
            bounds.Min,
        }
        local minX,minY = math.huge,math.huge
        local maxX,maxY = -math.huge,-math.huge
        local anyOnScreen = false
        for _, corner in ipairs(corners) do
            local sp, on = Camera:WorldToViewportPoint(corner)
            if on and sp.Z > 0 then
                anyOnScreen = true
                minX=math.min(minX,sp.X) minY=math.min(minY,sp.Y)
                maxX=math.max(maxX,sp.X) maxY=math.max(maxY,sp.Y)
            end
        end
        if not anyOnScreen then hideESPBox(box); continue end
        minX-=2 minY-=2 maxX+=2 maxY+=2
        local width, height = maxX-minX, maxY-minY
        local cx = (minX+maxX)/2

        -- visibility check — reuse cached params
        local isVisible = true
        if visCheck and myRoot then
            if not espRayParams[player] then
                local p = RaycastParams.new()
                p.FilterDescendantsInstances = {myChar, character}
                p.FilterType = Enum.RaycastFilterType.Exclude
                espRayParams[player] = p
            end
            local root2 = character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart
            if root2 then
                local dir = root2.Position - myRoot.Position
                isVisible = not workspace:Raycast(myRoot.Position, dir, espRayParams[player])
            end
        end
        local col = isVisible and visColor or boxColor

        -- boxes
        if showBoxes then
            box.Fill.Visible = true; box.Fill.Color = col
            box.Fill.Thickness = thickness
            box.Fill.Position = Vector2.new(minX+1, minY+1)
            box.Fill.Size = Vector2.new(width-2, height-2)
            box.Outline.Visible = true; box.Outline.Thickness = thickness+1
            box.Outline.Position = Vector2.new(minX, minY)
            box.Outline.Size = Vector2.new(width, height)
        else
            box.Fill.Visible = false; box.Outline.Visible = false
        end

        -- name
        box.NameText.Visible = showNames
        if showNames then
            box.NameText.Position = Vector2.new(cx, minY-18)
            box.NameText.Text = useDisplay and player.DisplayName or player.Name
            box.NameText.Color = col
        end

        -- in-car label
        box.StatusText.Visible = showNames and statusLabel ~= nil
        if showNames and statusLabel then
            box.StatusText.Position = Vector2.new(maxX+4, minY-18)
            box.StatusText.Text = statusLabel
            box.StatusText.Color = Color3.fromRGB(255,200,50)
        end

        -- distance (real world distance)
        box.DistText.Visible = showDist
        if showDist then
            local root3 = character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart
            local dist = myRoot and root3 and math.floor((myRoot.Position - root3.Position).Magnitude) or 0
            box.DistText.Position = Vector2.new(cx, minY-(showNames and 32 or 18))
            box.DistText.Text = dist.."m"
        end

        -- health bar
        box.HealthBg.Visible = showHealth; box.HealthFill.Visible = showHealth
        if showHealth and humanoid.MaxHealth > 0 then
            local pct = math.clamp(humanoid.Health/humanoid.MaxHealth, 0, 1)
            local barX = minX-6
            box.HealthBg.Position = Vector2.new(barX,minY); box.HealthBg.Size = Vector2.new(4,height)
            box.HealthFill.Color = Color3.new(1-pct,pct,0)
            box.HealthFill.Position = Vector2.new(barX+1, minY+1+(height-2)*(1-pct))
            box.HealthFill.Size = Vector2.new(2,(height-2)*pct)
        end
    end

    -- ======================================================
    -- PROXIMITY ALERTS
    -- ======================================================
    if Toggles.ESPArrows and Toggles.ESPArrows.Value then
        local dangerDist = Options.ESPArrowDanger and Options.ESPArrowDanger.Value or 1000
        local myRoot = LocalPlayer.Character and LocalPlayer.Character.PrimaryPart
        if myRoot and frameCount % 30 == 0 then  -- check every ~0.5s not every frame
            for _, player in pairs(Players:GetPlayers()) do
                if player == LocalPlayer then continue end
                local okA, charA = pcall(function() return getModel:Invoke(player) end)
                if not okA or not charA then continue end
                local rootA = charA.PrimaryPart or charA:FindFirstChild("HumanoidRootPart")
                if not rootA then continue end
                local dist3D = (myRoot.Position - rootA.Position).Magnitude
                if dist3D <= dangerDist then
                    -- Only notify once per player per cooldown window (10s)
                    local key = player.UserId
                    local now = tick()
                    if not notifCooldowns[key] or (now - notifCooldowns[key]) >= 10 then
                        notifCooldowns[key] = now
                        pushNotification(('Player Nearby,(%s): %.0fm'):format(player.Name, dist3D))
                        if Toggles.ProxSoundEnabled and Toggles.ProxSoundEnabled.Value then
                            local sid = Options.ProxSoundID and Options.ProxSoundID.Value or "9120385810"
                            local spt = Options.ProxSoundPitch and Options.ProxSoundPitch.Value or 1
                            playSound(sid, spt)
                        end
                    end
                end
            end
        end
    end

    -- ======================================================
    -- ESP LITE (cheap: HRP dot + text only, no bounds calc)
    -- ======================================================
    -- ======================================================
    -- ITEM MODEL CHAMS (RS > Items)
    -- ======================================================
    if Toggles.ItemChamEnabled and Toggles.ItemChamEnabled.Value then
        local baseCol = Options.ItemChamColor and Options.ItemChamColor.Value or Color3.fromRGB(0,200,255)
        -- Rescan every 30 frames in case loadout changed; instant on toggle-on
        itemChamScanFrame += 1
        if itemChamScanFrame >= 30 then
            itemChamScanFrame = 0
            itemChamParts = getItemParts()
        end
        -- Apply color every frame — no table wipe so rainbow works continuously
        for _, part in ipairs(itemChamParts) do
            if part and part.Parent then
                part.Material = Enum.Material.ForceField
                part.Color    = baseCol
                part.Transparency = 0
            end
        end
    end

    -- ======================================================
    -- ARM CHAMS (Camera > localmodel)
    -- ======================================================
    if Toggles.ArmChamEnabled and Toggles.ArmChamEnabled.Value then
        local rainbow = Toggles.ArmChamRainbow and Toggles.ArmChamRainbow.Value
        local armCol = Options.ArmChamColor and Options.ArmChamColor.Value or Color3.fromRGB(255,150,50)
        if rainbow then
            armRainbowHue = (armRainbowHue + 0.5) % 360
            armCol = Color3.fromHSV(armRainbowHue/360, 1, 1)
        end
        if frameCount % 10 == 0 then saveOriginals(getArmParts, armChamOriginals) end
        for part in pairs(armChamOriginals) do
            if part and part.Parent then
                part.Material = Enum.Material.ForceField
                part.Color    = armCol
                part.Transparency = 0
            end
        end
    end

    -- ======================================================
    -- CHAMS (ESP LITE)
    -- ======================================================
    local chamsOn = Toggles.ESPLiteEnabled and Toggles.ESPLiteEnabled.Value
    -- Only recolor parts every 6 frames (10Hz) - chams don't need per-frame updates
    if chamsOn and frameCount % 6 == 0 then
        local visCol = Options.ESPLiteVisColor and Options.ESPLiteVisColor.Value or Color3.fromRGB(0,255,100)
        local hidCol = Options.ESPLiteHidColor and Options.ESPLiteHidColor.Value or Color3.fromRGB(255,50,50)
        local showChamNames = Toggles.ESPLiteNames and Toggles.ESPLiteNames.Value
        local showChamDist  = Toggles.ESPLiteDist and Toggles.ESPLiteDist.Value
        local myRoot2 = LocalPlayer.Character and LocalPlayer.Character.PrimaryPart

        for _, player in pairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            local okL, charL = pcall(function() return getModel:Invoke(player) end)
            if not okL or not charL then
                if chamsData[player] then restoreChams(player) end
                continue
            end
            -- Save originals on first encounter
            if not chamsData[player] then
                saveOriginalParts(charL, player)
            end
            local data = chamsData[player]
            if not data then continue end

            -- Visibility check
            local col, isVis = applyChamsToChar(charL, visCol, hidCol, true)
            -- Apply color to parts
            setChamsParts(charL, col)

            -- Name/dist labels via Drawing
            local rootL = charL.PrimaryPart or charL:FindFirstChild("HumanoidRootPart")
            if rootL then
                -- Use smoothed HRP position to reduce jitter
                local smoothPos = rootL.Position
                if data.lastPos then
                    smoothPos = data.lastPos:Lerp(rootL.Position, 0.3)
                end
                data.lastPos = smoothPos
                local sp, on = Camera:WorldToViewportPoint(smoothPos + Vector3.new(0,2.5,0))
                if on and sp.Z > 0 then
                    if showChamNames then
                        data.nameLabel.Visible = true
                        data.nameLabel.Position = Vector2.new(sp.X, sp.Y - 2)
                        local useDN = Toggles.ESPLiteDisplayName and Toggles.ESPLiteDisplayName.Value
                        data.nameLabel.Text = useDN and player.DisplayName or player.Name
                        data.nameLabel.Color = col
                    else
                        data.nameLabel.Visible = false
                    end
                    if showChamDist and myRoot2 then
                        local d = math.floor((myRoot2.Position - rootL.Position).Magnitude)
                        data.distLabel.Visible = true
                        data.distLabel.Position = Vector2.new(sp.X, sp.Y + 14)
                        data.distLabel.Text = d .. "m"
                    else
                        data.distLabel.Visible = false
                    end
                else
                    data.nameLabel.Visible = false
                    data.distLabel.Visible = false
                end
            end
        end
    elseif not chamsOn then
        -- Restore all chams when disabled
        for player, _ in pairs(chamsData) do
            restoreChams(player)
        end
    end

    -- cleanup stale boxes every 60 frames
    if frameCount % 60 == 0 then
        for player, box in pairs(espBoxes) do
            if not Players:FindFirstChild(player.Name) then
                removeESPBox(box); espBoxes[player] = nil
                espRayParams[player] = nil
            end
        end
    end
end)

-- ============================================================
-- FOV CIRCLE + TARGET UPDATE
-- ============================================================
RunService:BindToRenderStep("FOVUpdate", Enum.RenderPriority.Camera.Value, function()
    local mousePos = UserInputService:GetMouseLocation()
    local rawR = Options.FOVRadius and Options.FOVRadius.Value or FOV_RADIUS
    local alRawR = Options.AimLockFOV and Options.AimLockFOV.Value or 150

    fovCircle.Position = Vector2.new(mousePos.X, mousePos.Y)
    fovCircle.Radius = getVisualRadius(rawR)
    fovCircle.Visible = Toggles.FOVCircleVisible and Toggles.FOVCircleVisible.Value

    local alOn = Toggles.AimLockEnabled and Toggles.AimLockEnabled.Value
    aimLockCircle.Position = Vector2.new(mousePos.X, mousePos.Y)
    aimLockCircle.Radius = getVisualRadius(alRawR)
    aimLockCircle.Visible = alOn
    aimLockCircle.Color = Options.AimLockCircleColor and Options.AimLockCircleColor.Value or Color3.fromRGB(122,235,150)

    local saOn = Toggles.SilentAimEnabled and Toggles.SilentAimEnabled.Value
    if not saOn then
        fovCircle.Color = Options.FOVCircleColor and Options.FOVCircleColor.Value or Color3.fromRGB(100,100,100)
        locked_player = nil; return
    end

    local newTarget = getTargetInFOV(rawR)
    -- SA blacklist: if target is blacklisted, treat as no target
    if newTarget and _G.cumyin_sablacklist then
        local name = newTarget.Name:lower()
        for _, banned in ipairs(_G.cumyin_sablacklist) do
            if name == banned:lower() then
                newTarget = nil
                break
            end
        end
    end
    if newTarget ~= locked_player then
        locked_player = newTarget
        if locked_player then
            fovCircle.Color = Options.FOVCircleLockedColor and Options.FOVCircleLockedColor.Value or Color3.fromRGB(122,199,235)
        else
            fovCircle.Color = Options.FOVCircleColor and Options.FOVCircleColor.Value or Color3.fromRGB(255,255,255)
        end
    end
end)

-- ============================================================
-- PLAYER REMOVING
-- ============================================================
Players.PlayerRemoving:Connect(function(p)
    if p == locked_player then locked_player = nil end
    if espBoxes[p] then removeESPBox(espBoxes[p]); espBoxes[p] = nil end
    if chamsData[p] then restoreChams(p) end
    espRayParams[p] = nil
end)

-- Clear lock when our character dies/resets
LocalPlayer.CharacterRemoving:Connect(function()
    locked_player = nil
end)

-- ============================================================
-- UI SETTINGS
-- ============================================================
local MenuGroup = Tabs['UI Settings']:AddLeftGroupbox('Menu')
MenuGroup:AddButton('Unload', function()
    -- ============================================================
    -- FULL CLEANUP
    -- ============================================================

    -- Drawing objects
    pcall(function() fovCircle:Remove() end)
    pcall(function() aimLine:Remove() end)
    pcall(function() aimLockCircle:Remove() end)

    -- ESP boxes
    for player, box in pairs(espBoxes) do
        pcall(function() removeESPBox(box) end)
    end
    espBoxes = {}

    -- ESP Lite chams — restore all original part colors
    for player, _ in pairs(chamsData) do
        pcall(function() restoreChams(player) end)
    end
    chamsData = {}

    -- Item chams — reset materials
    for _, part in ipairs(itemChamParts) do
        if part and part.Parent then
            pcall(function()
                part.Material = Enum.Material.SmoothPlastic
                part.Color = Color3.fromRGB(163, 162, 165)
            end)
        end
    end
    itemChamParts = {}

    -- Arm chams — restore originals
    pcall(function() restoreOriginals(armChamOriginals) end)

    -- Hitmark clone
    if hitmarkClone and hitmarkClone.Parent then
        pcall(function() hitmarkClone:Destroy() end)
        hitmarkClone = nil
    end

    -- Fly — stop and remove movers
    pcall(function()
        if flying then
            flying = false
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
            if hum then hum.PlatformStand = false end
            if flyBodyVelocity then flyBodyVelocity:Destroy(); flyBodyVelocity = nil end
            if flyBodyGyro then flyBodyGyro:Destroy(); flyBodyGyro = nil end
        end
    end)

    -- Restore hitbox sizes
    pcall(function()
        if Toggles.HitboxEnabled and Toggles.HitboxEnabled.Value then
            Toggles.HitboxEnabled:SetValue(false)
            updateHitboxes()
        end
    end)

    -- Restore deleted parts
    pcall(function()
        for _, entry in ipairs(deletedParts) do
            if entry.instance and entry.parent then
                entry.instance.Parent = entry.parent
                if entry.cframe and entry.instance:IsA("BasePart") then
                    entry.instance.CFrame = entry.cframe
                end
            end
        end
        deletedParts = {}
    end)

    -- Restore camera FOV
    pcall(function() Camera.FieldOfView = 70 end)

    -- Restore lighting
    pcall(function()
        Lighting.FogEnd = originalFogEnd
        Lighting.FogStart = originalFogStart
        Lighting.FogColor = originalFogColor
        Lighting.Ambient = originalAmbient
        Lighting.OutdoorAmbient = originalOutdoorAmbient
        Lighting.Brightness = originalBrightness
    end)

    -- Restore camera colour correction
    pcall(function()
        local cam = workspace:FindFirstChild("Camera")
        if cam then
            for _, name in ipairs({"healtheffect1", "ColourCorrection"}) do
                local fx = cam:FindFirstChild(name)
                if fx then fx.Enabled = true end
            end
        end
    end)

    -- Unhook silent aim — restore original newbullet
    pcall(function()
        if bullet_module and original_newbullet then
            pcall(hookfunction, original_newbullet, original_newbullet)
            bullet_module.newbullet = original_newbullet
        end
    end)

    -- Clear locked target
    locked_player = nil

    -- Speed hack cleanup
    pcall(cleanupSpeed)

    Library:Unload()
end)
