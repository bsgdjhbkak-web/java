-- Watermark update
task.spawn(function()
    local FPS = 60
    local fc = 0
    local ft = tick()
    while not IsUnloading do
        fc = fc + 1
        if (tick() - ft) >= 1 then 
            FPS = fc
            ft = tick()
            fc = 0
        end
        local ping = math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue())
        if CurrentSilentAimTarget and CurrentSilentAimTarget.Parent then
            local model = CurrentSilentAimTarget.Parent
            local myChar = local_player.Character
            local myRoot = myChar and (myChar:FindFirstChild("HumanoidRootPart") or myChar.PrimaryPart)
            local hum = model:FindFirstChildOfClass("Humanoid")
            local dist = myRoot and math.floor((myRoot.Position - CurrentSilentAimTarget.Position).Magnitude) or 0
            local hp = hum and math.floor(hum.Health) or 0
            Library:SetWatermark(("cumyin.pro | Target HP:%d | %dm | %dfps | %dms"):format(hp, dist, FPS, ping))
        else
            Library:SetWatermark(("cumyin.pro | No Target | %dfps | %dms"):format(FPS, ping))
        end
        task.wait(1)
    end
end)

